# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=change_me_in_env_local
# Reverse proxy IPs — set to REMOTE_ADDR behind a load balancer, or specific IPs.
# Leave empty for direct client connections (local dev).
# SYMFONY_TRUSTED_PROXIES=REMOTE_ADDR
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://expanded-decks.wip
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://expanded_decks:expanded_decks@127.0.0.1:3342/expanded_decks?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> symfony/messenger-webhook ###
# Shared secret for authenticating webhook-pushed messages (e.g. from SQS).
# Leave empty to disable webhook consumption (local dev default).
MESSENGER_WEBHOOK_SECRET=
###< symfony/messenger-webhook ###

###> symfony/session ###
# Session handler DSN — leave empty for filesystem (default).
# Redis: redis://localhost:6379 | PDO: %env(DATABASE_URL)%
SESSION_HANDLER_DSN=
###< symfony/session ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_TRANSACTIONAL_EMAIL_DSN=doctrine://default?auto_setup=0
MESSENGER_TRANSPORT_DECK_ENRICHMENT_DSN=doctrine://default?auto_setup=0
MESSENGER_TRANSPORT_NOTIFICATION_DSN=doctrine://default?auto_setup=0
MESSENGER_TRANSPORT_BORROW_LIFECYCLE_DSN=doctrine://default?auto_setup=0
MESSENGER_TRANSPORT_FAILED_DSN=doctrine://default?queue_name=failed
###< symfony/messenger ###

###> symfony/mailer ###
# Local dev: SMTP to Mailpit. Production examples:
# Amazon SES:  ses+smtp://ACCESS_KEY:SECRET@default?region=eu-west-1
# Postmark:    postmark+api://KEY@default
# Mailgun:     mailgun+api://KEY:DOMAIN@default
# SendGrid:    sendgrid+api://KEY@default
MAILER_DSN=smtp://localhost:1035
MAIL_SENDER=noreply@expanded-decks.wip
###< symfony/mailer ###

###> symfony/notifier ###
ADMIN_EMAIL=admin@example.com
###< symfony/notifier ###
