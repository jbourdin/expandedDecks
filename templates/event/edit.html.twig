{% extends 'base.html.twig' %}

{% block title %}{{ 'app.event.edit_title'|trans({'%name%': event.name}) }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="alert alert-info">
                <strong>{{ 'app.event.philosophy_notice.title'|trans }}</strong>
                <p class="mb-0">{{ 'app.event.philosophy_notice.notice_body'|trans }}</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-header card-header-themed">
                    <h5 class="mb-0">{{ 'app.event.edit_title'|trans({'%name%': event.name}) }}</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_row(form.name) }}

                        <div class="row" id="event-sync-row">
                            <div class="col-md-6">
                                <div class="d-flex align-items-end gap-2">
                                    <div class="flex-grow-1">{{ form_row(form.eventId) }}</div>
                                    <div class="mb-3">
                                        <button type="button" id="event-sync-btn" class="btn btn-outline-primary"
                                            data-sync-url="{{ path('app_event_sync') }}"
                                            data-error-empty="{{ 'app.event.sync.error_empty'|trans }}"
                                            data-confirm-overwrite="{{ 'app.event.sync.confirm_overwrite'|trans }}"
                                            data-success-msg="{{ 'app.event.sync.success'|trans }}"
                                            data-no-changes-msg="{{ 'app.event.sync.no_changes'|trans }}"
                                            data-error-network="{{ 'app.event.sync.error_network'|trans }}"
                                            title="{{ 'app.event.sync.tooltip'|trans }}">
                                            <i class="bi bi-arrow-repeat"></i> {{ 'app.event.sync.button'|trans }}
                                        </button>
                                    </div>
                                </div>
                            </div>
                            <div class="col-md-6">{{ form_row(form.format) }}</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.date) }}</div>
                            <div class="col-md-6">{{ form_row(form.endDate) }}</div>
                        </div>

                        {{ form_row(form.timezone) }}
                        {{ form_row(form.location) }}
                        {{ form_row(form.description) }}
                        {{ form_row(form.registrationLink) }}

                        {{ form_row(form.tournamentStructure) }}

                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.minAttendees) }}</div>
                            <div class="col-md-6">{{ form_row(form.maxAttendees) }}</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.roundDuration) }}</div>
                            <div class="col-md-6">{{ form_row(form.topCutRoundDuration) }}</div>
                        </div>

                        <div class="row">
                            <div class="col-md-6">{{ form_row(form.entryFeeAmount) }}</div>
                            <div class="col-md-6">{{ form_row(form.entryFeeCurrency) }}</div>
                        </div>

                        {{ form_row(form.isDecklistMandatory) }}

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-gold">{{ 'app.event.save_button'|trans }}</button>
                            <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-outline-secondary">{{ 'app.common.cancel'|trans }}</a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('event_sync') }}
{% endblock %}
