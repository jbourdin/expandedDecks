{% extends 'base.html.twig' %}

{% block title %}{{ 'app.event.available_decks_title'|trans }} — {{ event.name }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">{{ 'app.event.available_decks_title'|trans }}</h4>
        <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.event.back_to_event'|trans }}</a>
    </div>

    <p class="text-muted mb-4">
        {{ 'app.event.available_decks_for'|trans({'%name%': event.name})|raw }}
        ({{ include('event/_datetime.html.twig', {dt: event.date, tz: event.timezone, date_only: true}) }}).
    </p>

    {% if availableDecks is not empty %}
        <div class="row">
            {% for deck in availableDecks %}
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">
                                <a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{{ deck_sprites(deck) }}{{ deck.name }}</a>
                            </h6>
                            <p class="card-text text-muted mb-2">
                                {{ 'app.deck.owner'|trans }} {{ deck.owner.screenName }}
                                {% if deck.archetype and deck.archetype.deletedAt is null %}
                                    <br>{{ 'app.deck.archetype_label'|trans }} {% if deck.archetype.published %}<a href="{{ feature_url('archetypes', 'app_archetype_show', {slug: deck.archetype.slug}) }}"{{ not current_channel().enableArchetypes ? ' target="_blank" rel="noopener"' }}>{{ deck.archetype.localizedName(app.request.locale) }}</a>{% else %}{{ deck.archetype.localizedName(app.request.locale) }}{% endif %}
                                {% endif %}
                            </p>
                            {% if app.user %}
                                <form method="post" action="{{ path('app_borrow_request') }}">
                                    <input type="hidden" name="_token" value="{{ csrf_token('borrow-request-' ~ event.id) }}">
                                    <input type="hidden" name="event_id" value="{{ event.id }}">
                                    <input type="hidden" name="deck_id" value="{{ deck.id }}">
                                    <input type="hidden" name="redirect_to" value="event_decks">
                                    <div class="mb-2">
                                        <input type="text" name="notes" class="form-control form-control-sm" placeholder="{{ 'app.borrow.notes_label'|trans }}">
                                    </div>
                                    <button type="submit" class="btn btn-sm btn-primary">{{ 'app.event.request_to_borrow'|trans }}</button>
                                </form>
                            {% else %}
                                {# F3.24 — Anonymous viewers: redirect borrow CTA through sign-in #}
                                <a href="{{ path('app_login', {_target_path: app.request.requestUri}) }}" class="btn btn-sm btn-primary">{{ 'app.event.sign_in_to_borrow'|trans }}</a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-muted">{{ 'app.event.no_decks_available'|trans }}</p>
    {% endif %}
{% endblock %}
