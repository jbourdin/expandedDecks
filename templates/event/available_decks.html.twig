{% extends 'base.html.twig' %}

{% block title %}{{ 'app.event.available_decks_title'|trans }} — {{ event.name }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="mb-0">{{ 'app.event.available_decks_title'|trans }}</h4>
        <a href="{{ path('app_event_show', {id: event.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.event.back_to_event'|trans }}</a>
    </div>

    <p class="text-muted mb-4">
        {{ 'app.event.available_decks_for'|trans({'%name%': event.name})|raw }}
        ({% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone, date_only: true} %}).
    </p>

    {% if availableDecks is not empty %}
        <div class="row">
            {% for deck in availableDecks %}
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="card h-100">
                        <div class="card-body">
                            <h6 class="card-title">
                                <a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{% if deck.archetype %}{{ archetype_sprites(deck.archetype) }} {% endif %}{{ deck.name }}</a>
                            </h6>
                            <p class="card-text text-muted mb-2">
                                {{ 'app.deck.owner'|trans }} {{ deck.owner.screenName }}
                                {% if deck.archetype %}
                                    <br>{{ 'app.deck.archetype_label'|trans }} {% if deck.archetype.published %}<a href="{{ path('app_archetype_show', {slug: deck.archetype.slug}) }}">{{ deck.archetype.name }}</a>{% else %}{{ deck.archetype.name }}{% endif %}
                                {% endif %}
                            </p>
                            <form method="post" action="{{ path('app_borrow_request') }}">
                                <input type="hidden" name="_token" value="{{ csrf_token('borrow-request-' ~ event.id) }}">
                                <input type="hidden" name="event_id" value="{{ event.id }}">
                                <input type="hidden" name="deck_id" value="{{ deck.id }}">
                                <input type="hidden" name="redirect_to" value="event_decks">
                                <div class="mb-2">
                                    <input type="text" name="notes" class="form-control form-control-sm" placeholder="{{ 'app.borrow.notes_label'|trans }}">
                                </div>
                                <button type="submit" class="btn btn-sm btn-primary">{{ 'app.event.request_to_borrow'|trans }}</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <p class="text-muted">{{ 'app.event.no_decks_available'|trans }}</p>
    {% endif %}
{% endblock %}
