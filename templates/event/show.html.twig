{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% block title %}{{ event.name }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ event.name }}</h5>
            <div class="d-flex align-items-center gap-2">
                {% if event.cancelledAt %}
                    <span class="badge bg-danger">{{ 'app.event.badge_cancelled'|trans }}</span>
                {% elseif event.finishedAt %}
                    <span class="badge bg-secondary">{{ 'app.event.badge_finished'|trans }}</span>
                {% endif %}
                {% if event.invitationOnly %}
                    <span class="badge bg-warning text-dark">{{ 'app.event.badge_invitation_only'|trans }}</span>
                {% endif %}
                {% if event.eventId %}
                    <span class="badge bg-secondary">ID: {{ event.eventId }}</span>
                {% endif %}
                {% if isOrganizer and not event.cancelledAt %}
                    <a href="{{ path('app_event_edit', {id: event.id}) }}" class="btn btn-sm btn-outline-light">{{ 'app.common.edit'|trans }}</a>
                {% endif %}
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <table class="table table-sm table-themed mb-0">
                        <tbody>
                            <tr>
                                <th>{{ 'app.event.date'|trans }}</th>
                                <td>
                                    {% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone} %}
                                    {% if event.endDate %}
                                        — {% include 'event/_datetime.html.twig' with {dt: event.endDate, tz: event.timezone} %}
                                    {% endif %}
                                </td>
                            </tr>
                            <tr>
                                <th>{{ 'app.event.format'|trans }}</th>
                                <td>{{ event.format }}</td>
                            </tr>
                            <tr>
                                <th>{{ 'app.event.organizer'|trans }}</th>
                                <td>{{ event.organizer.screenName }}</td>
                            </tr>
                            {% if event.location %}
                                <tr>
                                    <th>{{ 'app.event.location'|trans }}</th>
                                    <td>{{ event.location }}</td>
                                </tr>
                            {% endif %}
                            {% if event.registrationLink %}
                            <tr>
                                <th>{{ 'app.event.registration_link'|trans }}</th>
                                <td><a href="{{ event.registrationLink }}" target="_blank" rel="noopener">{{ event.registrationLink }}</a></td>
                            </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>
                <div class="col-md-6">
                    <table class="table table-sm table-themed mb-0">
                        <tbody>
                            {% if event.tournamentStructure %}
                                <tr>
                                    <th>{{ 'app.event.structure'|trans }}</th>
                                    <td>{{ event.tournamentStructure.value|replace({'_': ' '})|title }}</td>
                                </tr>
                            {% endif %}
                            {% if event.minAttendees or event.maxAttendees %}
                                <tr>
                                    <th>{{ 'app.event.attendees'|trans }}</th>
                                    <td>
                                        {% if event.minAttendees %}{{ 'app.event.min'|trans({'%count%': event.minAttendees}) }}{% endif %}
                                        {% if event.minAttendees and event.maxAttendees %} / {% endif %}
                                        {% if event.maxAttendees %}{{ 'app.event.max'|trans({'%count%': event.maxAttendees}) }}{% endif %}
                                    </td>
                                </tr>
                            {% endif %}
                            {% if event.roundDuration or event.topCutRoundDuration %}
                                <tr>
                                    <th>{{ 'app.event.round_duration'|trans }}</th>
                                    <td>
                                        {% if event.roundDuration %}{{ 'app.event.round_min'|trans({'%duration%': event.roundDuration}) }}{% endif %}
                                        {% if event.roundDuration and event.topCutRoundDuration %} / {% endif %}
                                        {% if event.topCutRoundDuration %}{{ 'app.event.top_cut'|trans({'%duration%': event.topCutRoundDuration}) }}{% endif %}
                                    </td>
                                </tr>
                            {% endif %}
                            {% if event.entryFeeAmount is not null %}
                                <tr>
                                    <th>{{ 'app.event.entry_fee'|trans }}</th>
                                    <td>{{ (event.entryFeeAmount / 100)|number_format(2) }}{% if event.entryFeeCurrency %} {{ event.entryFeeCurrency }}{% endif %}</td>
                                </tr>
                            {% endif %}
                            <tr>
                                <th>{{ 'app.event.decklist_mandatory'|trans }}</th>
                                <td>{{ event.decklistMandatory ? 'app.common.yes'|trans : 'app.common.no'|trans }}</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            {% if event.description %}
                <hr>
                <p class="mb-0">{{ event.description|nl2br }}</p>
            {% endif %}
        </div>
    </div>

    {% if isOrganizer and not event.cancelledAt %}
        <div id="staff" class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.event.staff.title'|trans }}</h6>
            </div>
            <div class="card-body">
                {% if event.staff is not empty %}
                    <ul class="list-group list-group-flush mb-3">
                        {% for staffMember in event.staff %}
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                {{ staffMember.user.screenName }}
                                <form method="post" action="{{ path('app_event_remove_staff', {id: event.id, staffId: staffMember.id}) }}" class="d-inline">
                                    <input type="hidden" name="_token" value="{{ csrf_token('remove-staff-' ~ staffMember.id) }}">
                                    <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.event.staff.remove'|trans }}</button>
                                </form>
                            </li>
                        {% endfor %}
                    </ul>
                {% else %}
                    <p class="text-muted mb-3">{{ 'app.event.staff.no_staff'|trans }}</p>
                {% endif %}

                <form method="post" action="{{ path('app_event_assign_staff', {id: event.id}) }}" class="d-flex gap-2">
                    <input type="hidden" name="_token" value="{{ csrf_token('assign-staff-' ~ event.id) }}">
                    <div class="flex-grow-1"
                         data-staff-autocomplete
                         data-search-url="{{ path('app_user_search') }}"
                         data-hidden-input="user_query"
                         data-placeholder="{{ 'app.event.staff.placeholder'|trans }}">
                    </div>
                    <button type="submit" class="btn btn-sm btn-primary text-nowrap">{{ 'app.event.staff.add'|trans }}</button>
                </form>
            </div>
        </div>
    {% endif %}

    {% if not event.cancelledAt %}
        {# For invitation-only events, only invited users or organizer/staff can register as player #}
        {% set canRegisterAsPlayer = not event.invitationOnly
            or isStaff
            or (userEngagement and userEngagement.invitedBy is not null) %}
        <div id="participation" class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.event.participation.title'|trans }}</h6>
            </div>
            <div class="card-body">
                {% set playerCount = event.countByState(constant('App\\Enum\\EngagementState::RegisteredPlaying')) %}
                {% set spectatorCount = event.countByState(constant('App\\Enum\\EngagementState::RegisteredSpectating')) %}
                {% set interestedCount = event.countByState(constant('App\\Enum\\EngagementState::Interested')) %}
                {% set invitedCount = event.countByState(constant('App\\Enum\\EngagementState::Invited')) %}

                <p class="mb-3">
                    <strong>{{ 'app.event.participation.players'|trans({'%count%': playerCount}) }}</strong>,
                    <strong>{{ 'app.event.participation.spectators'|trans({'%count%': spectatorCount}) }}</strong>
                    {% if interestedCount > 0 %}, {{ 'app.event.participation.interested_count'|trans({'%count%': interestedCount}) }}{% endif %}
                    {% if invitedCount > 0 %}, {{ 'app.event.participation.invited_count'|trans({'%count%': invitedCount}) }}{% endif %}
                </p>

                {% if userEngagement %}
                    {% if userEngagement.state.value == 'registered_playing' %}
                        <span class="badge bg-success me-2">{{ 'app.event.participation.registered_playing'|trans }}</span>
                        <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                            <input type="hidden" name="mode" value="spectating">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'app.event.participation.switch_to_spectator'|trans }}</button>
                        </form>
                    {% elseif userEngagement.state.value == 'registered_spectating' %}
                        <span class="badge bg-info me-2">{{ 'app.event.participation.registered_spectating'|trans }}</span>
                        {% if canRegisterAsPlayer %}
                            <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                                <input type="hidden" name="mode" value="playing">
                                <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'app.event.participation.switch_to_player'|trans }}</button>
                            </form>
                        {% endif %}
                    {% elseif userEngagement.state.value == 'interested' or userEngagement.state.value == 'invited' %}
                        {% if userEngagement.state.value == 'interested' %}
                            <span class="badge bg-secondary me-2">{{ 'app.event.engagement.interested'|trans }}</span>
                        {% else %}
                            <span class="badge bg-primary me-2">{{ 'app.event.engagement.invited'|trans }}</span>
                        {% endif %}
                        {% if not event.finishedAt %}
                            {% if canRegisterAsPlayer %}
                                <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline me-1">
                                    <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                                    <input type="hidden" name="mode" value="playing">
                                    <button type="submit" class="btn btn-sm btn-primary">{{ 'app.event.participation.register_player'|trans }}</button>
                                </form>
                            {% endif %}
                            <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline">
                                <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                                <input type="hidden" name="mode" value="spectating">
                                <button type="submit" class="btn btn-sm btn-outline-primary">{{ 'app.event.participation.register_spectator'|trans }}</button>
                            </form>
                        {% endif %}
                    {% endif %}
                    <form method="post" action="{{ path('app_event_withdraw', {id: event.id}) }}" class="d-inline ms-1">
                        <input type="hidden" name="_token" value="{{ csrf_token('withdraw-event-' ~ event.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.event.participation.withdraw'|trans }}</button>
                    </form>
                {% else %}
                    {% if not event.finishedAt %}
                        {% if canRegisterAsPlayer %}
                            <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline me-1">
                                <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                                <input type="hidden" name="mode" value="playing">
                                <button type="submit" class="btn btn-sm btn-primary">{{ 'app.event.participation.register_player'|trans }}</button>
                            </form>
                        {% endif %}
                        <form method="post" action="{{ path('app_event_participate', {id: event.id}) }}" class="d-inline me-1">
                            <input type="hidden" name="_token" value="{{ csrf_token('participate-event-' ~ event.id) }}">
                            <input type="hidden" name="mode" value="spectating">
                            <button type="submit" class="btn btn-sm btn-outline-primary">{{ 'app.event.participation.register_spectator'|trans }}</button>
                        </form>
                        <form method="post" action="{{ path('app_event_interested', {id: event.id}) }}" class="d-inline">
                            <input type="hidden" name="_token" value="{{ csrf_token('interested-event-' ~ event.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-secondary">{{ 'app.event.interested_button'|trans }}</button>
                        </form>
                    {% endif %}
                {% endif %}

                {# Participants list with engagement badges #}
                {% if event.engagements is not empty %}
                    <hr>
                    <h6 class="text-muted mb-2">{{ 'app.event.participants_list'|trans }}</h6>
                    <ul class="list-group list-group-flush">
                        {% for engagement in event.engagements %}
                            <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                {{ engagement.user.screenName }}
                                {% if engagement.state.value == 'registered_playing' %}
                                    <span class="badge bg-success">{{ 'app.event.engagement.registered_playing'|trans }}</span>
                                {% elseif engagement.state.value == 'registered_spectating' %}
                                    <span class="badge bg-info">{{ 'app.event.engagement.registered_spectating'|trans }}</span>
                                {% elseif engagement.state.value == 'interested' %}
                                    <span class="badge bg-secondary">{{ 'app.event.engagement.interested'|trans }}</span>
                                {% elseif engagement.state.value == 'invited' %}
                                    <span class="badge bg-primary">{{ 'app.event.engagement.invited'|trans }}</span>
                                {% endif %}
                            </li>
                        {% endfor %}
                    </ul>
                {% endif %}

                {# Invite participant form (organizer/staff only) #}
                {% if isStaff and not event.finishedAt %}
                    <hr>
                    <h6 class="text-muted mb-2">{{ 'app.event.invite_participant'|trans }}</h6>
                    <form method="post" action="{{ path('app_event_invite', {id: event.id}) }}" class="d-flex gap-2">
                        <input type="hidden" name="_token" value="{{ csrf_token('invite-event-' ~ event.id) }}">
                        <div class="flex-grow-1"
                             data-staff-autocomplete
                             data-search-url="{{ path('app_user_search') }}"
                             data-hidden-input="user_query"
                             data-placeholder="{{ 'app.event.invite_placeholder'|trans }}">
                        </div>
                        <button type="submit" class="btn btn-sm btn-primary text-nowrap">{{ 'app.event.invite_button'|trans }}</button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {% if not event.cancelledAt and not event.finishedAt and ownedDecksWithVersion is not empty %}
        <div class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.event.your_decks'|trans }}</h6>
            </div>
            <div class="card-body">
                <p class="text-muted mb-2">{{ 'app.event.your_decks_help'|trans }}</p>
                <table class="table table-sm table-themed mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'app.borrow.table.deck'|trans }}</th>
                            <th>{{ 'app.borrow.table.status'|trans }}</th>
                            <th>{{ 'app.borrow.table.available'|trans }}</th>
                            <th>{{ 'app.borrow.table.delegate_to_staff'|trans }}</th>
                            <th>Custody</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for deck in ownedDecksWithVersion %}
                            {% set regInfo = deckRegistrationMap[deck.id] ?? null %}
                            {% set isRegistered = regInfo is not null and regInfo.registered %}
                            {% set isDelegated = regInfo is not null and regInfo.delegated %}
                            {% set isPlayed = currentDeckEntry is not null and currentDeckEntry.deckVersion.deck.id == deck.id %}
                            <tr>
                                <td><a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{{ deck.name }}</a></td>
                                <td>
                                    {% if isPlayed %}
                                        <span class="badge bg-primary">{{ 'app.event.deck_status_played'|trans }}</span>
                                    {% elseif isDelegated %}
                                        <span class="badge bg-info">{{ 'app.event.deck_status_delegated'|trans }}</span>
                                    {% elseif isRegistered %}
                                        <span class="badge bg-success">{{ 'app.event.deck_status_registered'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-secondary">{{ 'app.event.deck_status_not_registered'|trans }}</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <form method="post" action="{{ path('app_event_toggle_registration', {id: event.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-registration-' ~ event.id) }}">
                                        <input type="hidden" name="deck_id" value="{{ deck.id }}">
                                        {% if isRegistered %}
                                            <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.event.unregister'|trans }}</button>
                                        {% else %}
                                            <button type="submit" class="btn btn-sm btn-outline-success">{{ 'app.event.register_deck'|trans }}</button>
                                        {% endif %}
                                    </form>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('app_event_toggle_delegation', {id: event.id}) }}" class="d-inline">
                                        <input type="hidden" name="_token" value="{{ csrf_token('toggle-delegation-' ~ event.id) }}">
                                        <input type="hidden" name="deck_id" value="{{ deck.id }}">
                                        {% if isDelegated %}
                                            {% set deckWithStaff = regInfo.staffReceivedAt and not regInfo.staffReturnedAt %}
                                            <button type="submit" class="btn btn-sm btn-outline-warning" {{ (not isRegistered or deckWithStaff) ? 'disabled' }}
                                                {% if deckWithStaff %}title="Cannot revoke — deck is currently with staff"{% endif %}>{{ 'app.event.revoke'|trans }}</button>
                                        {% else %}
                                            <button type="submit" class="btn btn-sm btn-outline-info" {{ not isRegistered ? 'disabled' }}>{{ 'app.event.delegate'|trans }}</button>
                                        {% endif %}
                                    </form>
                                </td>
                                <td>
                                    {% if not isDelegated %}
                                        <span class="text-muted">&mdash;</span>
                                    {% elseif regInfo.staffReturnedAt %}
                                        <span class="badge bg-success">Returned to you</span>
                                    {% elseif regInfo.staffReceivedAt %}
                                        <span class="badge bg-info">With staff</span>
                                        <form method="post" action="{{ path('app_event_custody_owner_reclaim', {id: event.id, registrationId: regInfo.registrationId}) }}" class="d-inline ms-1">
                                            <input type="hidden" name="_token" value="{{ csrf_token('custody-owner-reclaim-' ~ regInfo.registrationId) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Mark returned to me</button>
                                        </form>
                                    {% elseif event.cancelledAt %}
                                        <span class="badge bg-secondary">{{ 'app.event.custody.cancelled'|trans }}</span>
                                    {% else %}
                                        <span class="badge bg-warning text-dark">Not handed over</span>
                                        <form method="post" action="{{ path('app_event_custody_owner_handover', {id: event.id, registrationId: regInfo.registrationId}) }}" class="d-inline ms-1">
                                            <input type="hidden" name="_token" value="{{ csrf_token('custody-owner-handover-' ~ regInfo.registrationId) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-primary">Hand to staff</button>
                                        </form>
                                    {% endif %}
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% endif %}

    {% if isStaff and (delegatedRegistrations is not empty or delegatedBorrows is not empty) %}
        <div class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.event.staff_custody'|trans }}</h6>
            </div>
            <div class="card-body p-0">
                {% if delegatedRegistrations is not empty %}
                    <div class="px-3 pt-3 pb-1">
                        <h6 class="text-muted mb-2">Physical Deck Handover</h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-themed mb-0">
                            <thead>
                                <tr>
                                    <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                    <th>{{ 'app.borrow.table.owner'|trans }}</th>
                                    <th>Custody</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for reg in delegatedRegistrations %}
                                    <tr>
                                        <td>
                                            <a href="{{ path('app_deck_show', {short_tag: reg.deck.shortTag}) }}">
                                                <span class="badge bg-dark badge-short-id me-1">{{ reg.deck.shortTag }}</span>{{ reg.deck.name }}
                                            </a>
                                        </td>
                                        <td>{{ reg.deck.owner.screenName }}</td>
                                        <td>
                                            {% if reg.staffReturnedAt %}
                                                <span class="badge bg-success">Returned to owner</span>
                                            {% elseif reg.staffReceivedAt %}
                                                <span class="badge bg-info">With staff</span>
                                            {% elseif event.cancelledAt %}
                                                <span class="badge bg-secondary">{{ 'app.event.custody.cancelled'|trans }}</span>
                                            {% else %}
                                                <span class="badge bg-warning text-dark">Awaiting handover</span>
                                            {% endif %}
                                        </td>
                                        <td class="text-end">
                                            {% if reg.staffReceivedAt and not reg.staffReturnedAt %}
                                                {% set hasLentBorrow = false %}
                                                {% for borrow in delegatedBorrows %}
                                                    {% if borrow.deck.id == reg.deck.id and borrow.status.value in ['lent', 'overdue'] %}
                                                        {% set hasLentBorrow = true %}
                                                    {% endif %}
                                                {% endfor %}
                                                <form method="post" action="{{ path('app_event_custody_staff_return', {id: event.id, registrationId: reg.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('custody-staff-return-' ~ reg.id) }}">
                                                    <button type="submit" class="btn btn-sm btn-outline-warning" {{ hasLentBorrow ? 'disabled' }}
                                                        {% if hasLentBorrow %}title="Collect the deck from the borrower first"{% endif %}>Mark returned to owner</button>
                                                </form>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}

                {% if delegatedBorrows is not empty and not event.cancelledAt and not event.finishedAt %}
                    <div class="px-3 pt-3 pb-1">
                        <h6 class="text-muted mb-2">Borrower Activity</h6>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-striped table-themed mb-0">
                            <thead>
                                <tr>
                                    <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                    <th>{{ 'app.borrow.table.owner'|trans }}</th>
                                    <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                    <th>{{ 'app.borrow.table.status'|trans }}</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for borrow in delegatedBorrows %}
                                    <tr>
                                        <td>
                                            <a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}">
                                                <span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}
                                            </a>
                                        </td>
                                        <td>{{ borrow.deck.owner.screenName }}</td>
                                        <td>{{ borrow.borrower.screenName }}</td>
                                        <td>{{ borrowBadge(borrow) }}</td>
                                        <td class="text-end">
                                            {% if borrow.status.value == 'pending' %}
                                                <form method="post" action="{{ path('app_borrow_approve', {id: borrow.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('approve-borrow-' ~ borrow.id) }}">
                                                    <input type="hidden" name="redirect_to" value="event">
                                                    <button type="submit" class="btn btn-sm btn-success">{{ 'app.borrow.approve_button'|trans }}</button>
                                                </form>
                                                <form method="post" action="{{ path('app_borrow_deny', {id: borrow.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'app.borrow.deny_confirm'|trans }}')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('deny-borrow-' ~ borrow.id) }}">
                                                    <input type="hidden" name="redirect_to" value="event">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.borrow.deny_button'|trans }}</button>
                                                </form>
                                            {% elseif borrow.status.value == 'approved' %}
                                                {% set awaitingCustody = false %}
                                                {% for reg in delegatedRegistrations %}
                                                    {% if reg.deck.id == borrow.deck.id and not reg.staffReceivedAt %}
                                                        {% set awaitingCustody = true %}
                                                    {% endif %}
                                                {% endfor %}
                                                <form method="post" action="{{ path('app_borrow_hand_off', {id: borrow.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('hand-off-borrow-' ~ borrow.id) }}">
                                                    <input type="hidden" name="redirect_to" value="event">
                                                    <button type="submit" class="btn btn-sm btn-primary" {{ awaitingCustody ? 'disabled' }}
                                                        {% if awaitingCustody %}title="Owner must hand over the deck to staff first"{% endif %}>{{ 'app.event.hand_off'|trans }}</button>
                                                </form>
                                            {% elseif borrow.status.value == 'lent' or borrow.status.value == 'overdue' %}
                                                <form method="post" action="{{ path('app_borrow_return', {id: borrow.id}) }}" class="d-inline">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('return-borrow-' ~ borrow.id) }}">
                                                    <input type="hidden" name="redirect_to" value="event">
                                                    <button type="submit" class="btn btn-sm btn-warning">{{ 'app.event.mark_returned'|trans }}</button>
                                                </form>
                                            {% endif %}
                                            {% if borrow.status.value in ['pending', 'approved'] %}
                                                <form method="post" action="{{ path('app_borrow_cancel', {id: borrow.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'app.borrow.cancel_confirm'|trans }}')">
                                                    <input type="hidden" name="_token" value="{{ csrf_token('cancel-borrow-' ~ borrow.id) }}">
                                                    <input type="hidden" name="redirect_to" value="event">
                                                    <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.borrow.cancel_button'|trans }}</button>
                                                </form>
                                            {% endif %}
                                            <a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a>
                                        </td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {% if not event.cancelledAt and not event.finishedAt %}
        {% set activeBorrows = eventBorrows|filter(b => b.borrower.id == app.user.id and b.status.value in ['pending', 'approved', 'lent', 'overdue']) %}

        {% if isParticipant and (playableOwnDecks is not empty or activeBorrows is not empty) %}
            <div class="card shadow-sm mb-3">
                <div class="card-header card-header-themed">
                    <h6 class="mb-0">{{ 'app.event.deck_selection'|trans }}</h6>
                </div>
                <div class="card-body">
                    {% set selectedDeckId = currentDeckEntry ? currentDeckEntry.deckVersion.deck.id : 0 %}
                    <form method="post" action="{{ path('app_event_select_deck', {id: event.id}) }}">
                        <input type="hidden" name="_token" value="{{ csrf_token('select-deck-' ~ event.id) }}">
                        <table class="table table-sm table-themed mb-2">
                            <thead>
                                <tr>
                                    <th style="width: 40px;">{{ 'app.borrow.table.play'|trans }}</th>
                                    <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                    <th>{{ 'app.borrow.table.status'|trans }}</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td>
                                        <input type="radio" name="deck_id" value="0" class="form-check-input"
                                            {{ selectedDeckId == 0 ? 'checked' }}
                                            {{ not canChangeDeck ? 'disabled' }}>
                                    </td>
                                    <td colspan="2" class="text-muted">{{ 'app.event.no_deck_selected'|trans }}</td>
                                    <td></td>
                                </tr>
                                {% for deck in playableOwnDecks %}
                                    {% set regInfo = deckRegistrationMap[deck.id] ?? null %}
                                    {% set isWithStaff = regInfo is not null and regInfo.delegated and regInfo.staffReceivedAt and not regInfo.staffReturnedAt %}
                                    {% set isDeckLent = deck.status.value == 'lent' %}
                                    {% set isUnavailable = isWithStaff or isDeckLent %}
                                    <tr>
                                        <td>
                                            <input type="radio" name="deck_id" value="{{ deck.id }}" class="form-check-input"
                                                {{ selectedDeckId == deck.id ? 'checked' }}
                                                {{ (not canChangeDeck or isUnavailable) ? 'disabled' }}>
                                        </td>
                                        <td><a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{{ deck.name }}</a></td>
                                        <td>
                                            {% if isWithStaff %}
                                                <span class="badge bg-info">With staff</span>
                                            {% elseif isDeckLent %}
                                                <span class="badge bg-warning text-dark">Lent</span>
                                            {% else %}
                                                <span class="badge bg-secondary">{{ 'app.event.own_deck'|trans }}</span>
                                            {% endif %}
                                        </td>
                                        <td>
                                            {% if isUnavailable %}
                                                <a href="{{ path('app_event_decks', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">Browse decks</a>
                                            {% endif %}
                                        </td>
                                    </tr>
                                {% endfor %}
                                {% for borrow in activeBorrows %}
                                    {% set isBorrowPlayable = borrow.status.value in ['approved', 'lent'] %}
                                    <tr>
                                        <td>
                                            <input type="radio" name="deck_id" value="{{ borrow.deck.id }}" class="form-check-input"
                                                {{ selectedDeckId == borrow.deck.id ? 'checked' }}
                                                {{ (not canChangeDeck or not isBorrowPlayable) ? 'disabled' }}>
                                        </td>
                                        <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}</a></td>
                                        <td>{{ borrowBadge(borrow) }}</td>
                                        <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                        <div class="d-flex align-items-center gap-2 mt-3">
                            {% if canChangeDeck %}
                                <button type="submit" class="btn btn-sm btn-primary">{{ 'app.event.save_selection'|trans }}</button>
                            {% endif %}
                            <a href="{{ path('app_event_decks', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">
                                {{ 'app.event.browse_available'|trans }}
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        {% endif %}

        <div id="borrowing" class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.event.deck_borrowing'|trans }}</h6>
            </div>
            <div class="card-body">
                {% if isStaff %}
                    <a href="{{ path('app_event_walk_up', {id: event.id}) }}" class="btn btn-sm btn-outline-primary mb-3">
                        {{ 'app.event.walk_up.walk_up_lend'|trans }}
                    </a>
                {% endif %}

                {% if not isParticipant %}
                    <p class="text-muted mb-3">{{ 'app.event.participation.register_to_browse'|trans }}</p>
                {% elseif playableOwnDecks is empty and activeBorrows is empty %}
                    <a href="{{ path('app_event_decks', {id: event.id}) }}" class="btn btn-primary mb-3">
                        {{ 'app.event.browse_available'|trans }}
                    </a>
                {% endif %}

                {% set otherBorrows = eventBorrows|filter(b => not (b.borrower.id == app.user.id and b.status.value in ['pending', 'approved', 'lent', 'overdue'])) %}
                {% if otherBorrows is not empty %}
                    <table class="table table-sm table-themed mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                <th>{{ 'app.borrow.table.status'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for borrow in otherBorrows %}
                                <tr>
                                    <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}</a></td>
                                    <td>{{ borrow.borrower.screenName }}</td>
                                    <td>{{ borrowBadge(borrow) }}</td>
                                    <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                {% else %}
                    <p class="text-muted mb-0">{{ 'app.event.no_borrow_activity'|trans }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <div class="d-flex gap-2">
        <a href="{{ path('app_event_list') }}" class="btn btn-sm btn-outline-secondary">{{ 'app.event.back_to_events'|trans }}</a>
        {% if event.finishedAt and not event.cancelledAt %}
            {% if hasResults %}
                <a href="{{ path('app_event_results', {id: event.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'app.event.results.view_results'|trans }}</a>
            {% endif %}
            {% if isOrganizer or isStaff %}
                <a href="{{ path('app_event_results_edit', {id: event.id}) }}" class="btn btn-sm btn-outline-secondary">
                    {% if hasResults %}
                        {{ 'app.event.results.edit_results'|trans }}
                    {% else %}
                        {{ 'app.event.results.enter_results'|trans }}
                    {% endif %}
                </a>
            {% endif %}
        {% endif %}
        {% if isOrganizer and not event.cancelledAt %}
            {% if not event.finishedAt %}
                <form method="post" action="{{ path('app_event_finish', {id: event.id}) }}" onsubmit="return confirm('{{ 'app.event.finish_confirm'|trans }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('finish-event-' ~ event.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-success">{{ 'app.event.finish_event'|trans }}</button>
                </form>
                <form method="post" action="{{ path('app_event_cancel', {id: event.id}) }}" onsubmit="return confirm('{{ 'app.event.cancel_confirm'|trans }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('cancel-event-' ~ event.id) }}">
                    <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.event.cancel_event'|trans }}</button>
                </form>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {% if isOrganizer and not event.cancelledAt %}
        {{ encore_entry_link_tags('staff_autocomplete') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if isOrganizer and not event.cancelledAt %}
        {{ encore_entry_script_tags('staff_autocomplete') }}
    {% endif %}
{% endblock %}
