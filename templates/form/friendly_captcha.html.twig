{# Friendly Captcha v2 widget — @see docs/features.md F12.4 #}
{% block friendly_captcha_row %}
    <div class="mb-3">
        <div class="frc-captcha" data-sitekey="{{ sitekey }}" data-form-field-name="{{ full_name }}"></div>
        {% if errors|length > 0 %}
            <div class="invalid-feedback d-block">
                {{ form_errors(form) }}
            </div>
        {% endif %}
    </div>
{% endblock %}
