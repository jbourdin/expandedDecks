{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% block title %}{{ pageTitle }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h1 class="mb-0">{{ pageTitle }}</h1>
        <a href="{{ path('app_dashboard') }}" class="btn btn-sm btn-outline-secondary">{{ 'app.nav.dashboard'|trans }}</a>
    </div>

    {% set listRoute = mode == 'borrows' ? 'app_borrow_list' : 'app_lend_list' %}
    {% set scopeParams = scope is defined and scope == 'managed' ? {scope: 'managed'} : {} %}
    <div class="mb-3 d-flex flex-wrap gap-1">
        <a href="{{ path(listRoute, scopeParams) }}"
           class="btn btn-sm {{ currentStatus is null ? 'btn-primary' : 'btn-outline-secondary' }}">
            {{ 'app.borrow.list_all'|trans }}
        </a>
        {% for status in statuses %}
            <a href="{{ path(listRoute, scopeParams|merge({status: status.value})) }}"
               class="btn btn-sm {{ currentStatus is not null and currentStatus.value == status.value ? 'btn-primary' : 'btn-outline-secondary' }}">
                {{ status.value|replace({'_': ' '})|title }}
            </a>
        {% endfor %}
    </div>

    {% if inboxMode is defined and inboxMode %}
        {# Inbox mode: active borrows grouped by event #}
        {% if eventGroups|length > 0 %}
            {% include 'borrow/_inbox.html.twig' %}
        {% else %}
            <div class="card shadow-sm">
                <div class="card-body text-center py-5">
                    <p class="text-muted mb-0">{{ 'app.borrow.no_active_borrows'|trans }}</p>
                </div>
            </div>
        {% endif %}
    {% elseif totalItems > 0 %}
        {% set params = scopeParams|merge(currentStatus is not null ? {status: currentStatus.value} : {}) %}

        <p class="text-muted mb-3">
            {% set firstItem = ((currentPage - 1) * 20) + 1 %}
            {% set lastItem = currentPage * 20 %}
            {{ 'app.common.showing'|trans({'%first%': firstItem, '%last%': lastItem < totalItems ? lastItem : totalItems, '%total%': totalItems}) }}
        </p>

        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-themed mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                <th>{{ 'app.borrow.table.event'|trans }}</th>
                                {% if mode != 'borrows' %}
                                    <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                {% else %}
                                    <th>{{ 'app.borrow.table.owner'|trans }}</th>
                                {% endif %}
                                <th>{{ 'app.borrow.table.status'|trans }}</th>
                                <th>{{ 'app.borrow.table.date'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for borrow in borrows %}
                                <tr>
                                    <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{% if borrow.deck.archetype %}{{ archetype_sprites(borrow.deck.archetype) }} {% endif %}{{ borrow.deck.name }}</a></td>
                                    <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                                    {% if mode != 'borrows' %}
                                        <td>{{ borrow.borrower.screenName }}</td>
                                    {% else %}
                                        <td>{{ borrow.deck.owner.screenName }}</td>
                                    {% endif %}
                                    <td>{{ borrowBadge(borrow) }}</td>
                                    <td>{{ borrow.requestedAt|user_date }}</td>
                                    <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {% if totalPages > 1 %}
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                        <a class="page-link" href="{{ path(listRoute, params|merge({page: currentPage - 1})) }}">{{ 'app.common.previous'|trans }}</a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item {% if p == currentPage %}active{% endif %}">
                            <a class="page-link" href="{{ path(listRoute, params|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                        <a class="page-link" href="{{ path(listRoute, params|merge({page: currentPage + 1})) }}">{{ 'app.common.next'|trans }}</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                {% if mode == 'managed' %}
                    <p class="text-muted mb-0">{{ 'app.borrow.no_managed_borrows'|trans }}</p>
                {% elseif mode == 'lends' %}
                    <p class="text-muted mb-0">{{ 'app.borrow.no_lends'|trans }}</p>
                {% else %}
                    <p class="text-muted mb-0">{{ 'app.borrow.no_borrows'|trans }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
