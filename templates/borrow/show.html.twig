{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% block title %}Borrow — {{ borrow.deck.name }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.borrow.title'|trans({'%name%': borrow.deck.name}) }}: <a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}" class="text-white">{{ borrow.deck.name }}</a></h5>
            {{ borrowBadge(borrow) }}
        </div>
        <div class="card-body">
            <table class="table table-sm table-themed mb-0">
                <tbody>
                    <tr>
                        <th>{{ 'app.borrow.table.deck'|trans }}</th>
                        <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}">{{ borrow.deck.name }}</a></td>
                    </tr>
                    <tr>
                        <th>{{ 'app.borrow.table.event'|trans }}</th>
                        <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                    </tr>
                    <tr>
                        <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                        <td>{{ borrow.borrower.screenName }}</td>
                    </tr>
                    <tr>
                        <th>{{ 'app.borrow.table.owner'|trans }}</th>
                        <td>{{ borrow.deck.owner.screenName }}</td>
                    </tr>
                    {% if borrow.isDelegatedToStaff %}
                        <tr>
                            <th>{{ 'app.borrow.delegated_badge'|trans }}</th>
                            <td><span class="badge bg-info">{{ 'app.borrow.delegated_badge'|trans }}</span></td>
                        </tr>
                    {% endif %}
                    {% if borrow.notes %}
                        <tr>
                            <th>{{ 'app.borrow.notes_label'|trans }}</th>
                            <td>{{ borrow.notes }}</td>
                        </tr>
                    {% endif %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h6 class="mb-0">{{ 'app.borrow.timeline'|trans }}</h6>
        </div>
        <div class="card-body">
            <ul class="list-unstyled mb-0">
                <li>
                    <strong>{{ 'app.borrow.requested'|trans }}</strong>
                    {{ borrow.requestedAt|user_datetime }}
                    {{ 'app.borrow.by'|trans({'%name%': borrow.borrower.screenName}) }}
                </li>
                {% if borrow.approvedAt %}
                    <li class="mt-1">
                        <strong>{{ 'app.borrow.approved'|trans }}</strong>
                        {{ borrow.approvedAt|user_datetime }}
                        {% if borrow.approvedBy %}{{ 'app.borrow.by'|trans({'%name%': borrow.approvedBy.screenName}) }}{% endif %}
                    </li>
                {% endif %}
                {% if borrow.handedOffAt %}
                    <li class="mt-1">
                        <strong>{{ 'app.borrow.handed_off'|trans }}</strong>
                        {{ borrow.handedOffAt|user_datetime }}
                        {% if borrow.handedOffBy %}{{ 'app.borrow.by'|trans({'%name%': borrow.handedOffBy.screenName}) }}{% endif %}
                    </li>
                {% endif %}
                {% if borrow.returnedAt %}
                    <li class="mt-1">
                        <strong>{{ 'app.borrow.returned'|trans }}</strong>
                        {{ borrow.returnedAt|user_datetime }}
                        {% if borrow.returnedTo %}{{ 'app.borrow.to'|trans({'%name%': borrow.returnedTo.screenName}) }}{% endif %}
                    </li>
                {% endif %}
                {% if borrow.returnedToOwnerAt %}
                    <li class="mt-1">
                        <strong>{{ 'app.borrow.returned_to_owner'|trans }}</strong>
                        {{ borrow.returnedToOwnerAt|user_datetime }}
                    </li>
                {% endif %}
                {% if borrow.cancelledAt %}
                    <li class="mt-1">
                        <strong>{{ 'app.borrow.cancelled'|trans }}</strong>
                        {{ borrow.cancelledAt|user_datetime }}
                        {% if borrow.cancelledBy %}{{ 'app.borrow.by'|trans({'%name%': borrow.cancelledBy.screenName}) }}{% endif %}
                    </li>
                {% endif %}
            </ul>
        </div>
    </div>

    {% if canApprove or canDeny or canHandOff or canReturn or canCancel or canReturnToOwner %}
        <div class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h6 class="mb-0">{{ 'app.borrow.actions'|trans }}</h6>
            </div>
            <div class="card-body d-flex gap-2 flex-wrap align-items-center">
                {% if canApprove %}
                    <form method="post" action="{{ path('app_borrow_approve', {id: borrow.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-success">{{ 'app.borrow.approve_button'|trans }}</button>
                    </form>
                {% endif %}
                {% if canDeny %}
                    <form method="post" action="{{ path('app_borrow_deny', {id: borrow.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'app.borrow.deny_confirm'|trans }}')">
                        <input type="hidden" name="_token" value="{{ csrf_token('deny-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.borrow.deny_button'|trans }}</button>
                    </form>
                {% endif %}
                {% if canHandOff %}
                    <form method="post" action="{{ path('app_borrow_hand_off', {id: borrow.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('hand-off-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-primary">{{ 'app.borrow.hand_off_button'|trans }}</button>
                    </form>
                {% endif %}
                {% if canReturn %}
                    <form method="post" action="{{ path('app_borrow_return', {id: borrow.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('return-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-primary">{{ 'app.borrow.return_button'|trans }}</button>
                    </form>
                {% endif %}
                {% if canReturnToOwner %}
                    <form method="post" action="{{ path('app_borrow_return_to_owner', {id: borrow.id}) }}" class="d-inline">
                        <input type="hidden" name="_token" value="{{ csrf_token('return-to-owner-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-primary">{{ 'app.borrow.return_to_owner_button'|trans }}</button>
                    </form>
                {% endif %}
                {% if canCancel %}
                    <form method="post" action="{{ path('app_borrow_cancel', {id: borrow.id}) }}" class="d-inline" onsubmit="return confirm('{{ 'app.borrow.cancel_confirm'|trans }}')">
                        <input type="hidden" name="_token" value="{{ csrf_token('cancel-borrow-' ~ borrow.id) }}">
                        <button type="submit" class="btn btn-sm btn-outline-danger">{{ 'app.borrow.cancel_button'|trans }}</button>
                    </form>
                {% endif %}
            </div>
        </div>
    {% endif %}

    <a href="{{ path('app_event_show', {id: borrow.event.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.borrow.back_to_event'|trans }}</a>
{% endblock %}
