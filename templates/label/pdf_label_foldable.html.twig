<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4 landscape;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Helvetica, Arial, sans-serif;
            width: 297mm;
            height: 210mm;
            position: relative;
        }

        .page {
            width: 297mm;
            height: 210mm;
            position: relative;
        }

        /* Two panels side by side (book layout)
         * Each panel: 63.5 × 88.9 mm outer
         * Content-box: 62.9 × 83.3 mm (border 0.3mm×2, padding 3mm+2mm)
         * Panels are adjacent at the horizontal center
         * Left = deck list (back), Right = label (front)
         * Fold along the center vertical line like a book
         */
        .panel {
            width: 62.9mm;
            height: 83.3mm;
            border: 0.3mm solid #ccc;
            position: absolute;
            top: 50%;
            margin-top: -44.45mm;
            text-align: center;
            padding: 3mm 0 2mm;
            overflow: hidden;
        }

        /* Left panel (deck list / back side) — right edge at page center */
        .panel-back {
            right: 50%;
        }

        /* Right panel (label / front side) — left edge at page center */
        .panel-front {
            left: 50%;
        }

        /* Fold line between panels */
        .fold-line {
            position: absolute;
            left: 50%;
            top: calc(50% - 44.45mm - 10mm);
            height: calc(88.9mm + 20mm);
            width: 0;
            border-left: 0.3mm dashed #bbb;
        }

        /* Crop marks */
        .crop-mark {
            position: absolute;
            background: #000;
        }

        /* Horizontal marks — top and bottom edges of both panels */
        .crop-top-l  { height: 0.2mm; top: calc(50% - 44.45mm); left: 0; right: calc(50% + 63.5mm + 2mm); }
        .crop-top-r  { height: 0.2mm; top: calc(50% - 44.45mm); left: calc(50% + 63.5mm + 2mm); right: 0; }
        .crop-bot-l  { height: 0.2mm; top: calc(50% + 44.45mm); left: 0; right: calc(50% + 63.5mm + 2mm); }
        .crop-bot-r  { height: 0.2mm; top: calc(50% + 44.45mm); left: calc(50% + 63.5mm + 2mm); right: 0; }

        /* Vertical marks — outer edges of the pair */
        .crop-v-tl { width: 0.2mm; height: 5mm; top: calc(50% - 44.45mm - 7mm); left: calc(50% - 63.5mm); }
        .crop-v-tr { width: 0.2mm; height: 5mm; top: calc(50% - 44.45mm - 7mm); left: calc(50% + 63.5mm); }
        .crop-v-bl { width: 0.2mm; height: 5mm; top: calc(50% + 44.45mm + 2mm); left: calc(50% - 63.5mm); }
        .crop-v-br { width: 0.2mm; height: 5mm; top: calc(50% + 44.45mm + 2mm); left: calc(50% + 63.5mm); }

        /* === Front panel styles === */
        .deck-name {
            font-size: 12pt;
            font-weight: bold;
            margin: 1mm 3mm 1mm;
            line-height: 1.2;
            color: #1a1a1a;
        }

        .sprites {
            margin: 1mm 0 1mm;
            line-height: 0;
        }

        .sprite-img {
            width: 12mm;
            height: 12mm;
            margin: 0 1mm;
        }

        .separator {
            border-top: 0.3mm solid #ddd;
            margin: 1.5mm 0;
        }

        .qr-code {
            width: 18mm;
            height: 18mm;
            margin: 1.5mm auto 1mm;
        }

        .short-tag {
            font-size: 9pt;
            font-family: 'Courier New', Courier, monospace;
            letter-spacing: 1.5pt;
            color: #333;
            margin: 1mm 0;
        }

        .screen-name {
            font-size: 10pt;
            color: #333;
            margin: 1mm 0 0;
        }

        .full-name {
            font-size: 7.5pt;
            color: #777;
            margin: 0.5mm 0 0;
        }

        .base-url {
            font-size: 6.5pt;
            color: #aaa;
            margin: 0 3mm;
        }

        /* === Back panel styles (deck list) === */
        .decklist-section {
            margin: 0;
            padding: 0.5mm 2mm;
            text-align: left;
        }

        .decklist-shade-0 { background: #ffffff; }
        .decklist-shade-1 { background: #f4f4f4; }

        .decklist-card {
            font-size: {{ decklistFontSize }}pt;
            line-height: 1.4;
            color: #333;
        }

        .decklist-qty {
            font-weight: bold;
            display: inline;
            color: #555;
        }

        .decklist-set {
            color: #999;
            font-size: {{ (decklistFontSize - 0.5)|round(1) }}pt;
        }

        .decklist-footer {
            font-size: 5pt;
            color: #aaa;
            text-align: center;
            margin-top: 1mm;
        }
    </style>
</head>
<body>
    <div class="page">
        {# Crop marks #}
        <div class="crop-mark crop-top-l"></div>
        <div class="crop-mark crop-top-r"></div>
        <div class="crop-mark crop-bot-l"></div>
        <div class="crop-mark crop-bot-r"></div>
        <div class="crop-mark crop-v-tl"></div>
        <div class="crop-mark crop-v-tr"></div>
        <div class="crop-mark crop-v-bl"></div>
        <div class="crop-mark crop-v-br"></div>

        {# Fold line #}
        <div class="fold-line"></div>

        {# Left panel — deck list (back when folded) #}
        <div class="panel panel-back">
            {% for type, cards in groupedCards %}
                <div class="decklist-section decklist-shade-{{ loop.index0 % 2 }}">
                    {% for card in cards %}
                        <div class="decklist-card">
                            <span class="decklist-qty">{{ card.quantity }}</span> {{ card.cardName }} <span class="decklist-set">{{ card.setCode }} {{ card.cardNumber }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}
        </div>

        {# Right panel — label (front when folded) #}
        <div class="panel panel-front">
            <div class="deck-name">{{ deck.name }}</div>

            {% if spriteDataUris is not empty %}
                <div class="sprites">
                    {% for sprite in spriteDataUris %}
                        <img src="{{ sprite.dataUri }}" alt="{{ sprite.name }}" class="sprite-img">
                    {% endfor %}
                </div>
            {% endif %}

            <div class="separator"></div>

            <img src="{{ qrCodeDataUri }}" class="qr-code" alt="QR Code">

            <div class="short-tag">{{ deck.shortTag }}</div>

            <div class="separator"></div>

            <div class="screen-name">{{ deck.owner.screenName }}</div>
            <div class="full-name">{{ deck.owner.firstName }} {{ deck.owner.lastName }}</div>

            <div class="separator"></div>

            <div class="base-url">{{ baseUrl }}</div>
        </div>
    </div>
</body>
</html>
