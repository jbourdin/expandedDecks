<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <style>
        @page {
            size: A4;
            margin: 0;
        }

        * {
            margin: 0;
            padding: 0;
        }

        body {
            font-family: Helvetica, Arial, sans-serif;
            width: 210mm;
            height: 297mm;
            position: relative;
        }

        .page {
            width: 210mm;
            height: 297mm;
            position: relative;
        }

        /* Two panels stacked vertically, centered horizontally
         * Each panel: 63.5 × 88.9 mm outer
         * Content-box: 62.9 × 83.3 mm (border 0.3mm×2, padding 3mm+2mm)
         * Combined height: 88.9 × 2 = 177.8 mm
         * Vertical offset from center: 88.9mm
         */
        .panel {
            width: 62.9mm;
            height: 83.3mm;
            border: 0.3mm solid #ccc;
            position: absolute;
            left: 50%;
            margin-left: -31.75mm;
            text-align: center;
            padding: 3mm 0 2mm;
            overflow: hidden;
        }

        /* Front panel (top) — label content */
        .panel-front {
            top: calc(50% - 88.9mm);
        }

        /* Back panel (bottom) — deck list */
        .panel-back {
            top: 50%;
        }

        /* Fold line between panels */
        .fold-line {
            position: absolute;
            top: 50%;
            left: calc(50% - 31.75mm - 10mm);
            width: calc(63.5mm + 20mm);
            height: 0;
            border-top: 0.3mm dashed #bbb;
        }

        /* Crop marks */
        .crop-h, .crop-v {
            position: absolute;
            background: #000;
        }

        /* Horizontal marks — top and bottom of the combined pair */
        .crop-top-l    { height: 0.2mm; top: calc(50% - 88.9mm); left: 0; right: calc(50% + 31.75mm + 2mm); }
        .crop-top-r    { height: 0.2mm; top: calc(50% - 88.9mm); left: calc(50% + 31.75mm + 2mm); right: 0; }
        .crop-bottom-l { height: 0.2mm; top: calc(50% + 88.9mm); left: 0; right: calc(50% + 31.75mm + 2mm); }
        .crop-bottom-r { height: 0.2mm; top: calc(50% + 88.9mm); left: calc(50% + 31.75mm + 2mm); right: 0; }

        /* Vertical marks */
        .crop-vtl { width: 0.2mm; height: 5mm; top: calc(50% - 88.9mm - 7mm); left: calc(50% - 31.75mm); }
        .crop-vtr { width: 0.2mm; height: 5mm; top: calc(50% - 88.9mm - 7mm); left: calc(50% + 31.75mm); }
        .crop-vbl { width: 0.2mm; height: 5mm; top: calc(50% + 88.9mm + 2mm); left: calc(50% - 31.75mm); }
        .crop-vbr { width: 0.2mm; height: 5mm; top: calc(50% + 88.9mm + 2mm); left: calc(50% + 31.75mm); }

        /* === Front panel styles === */
        .deck-name {
            font-size: 12pt;
            font-weight: bold;
            margin: 1mm 3mm 1mm;
            line-height: 1.2;
            color: #1a1a1a;
        }

        .sprites {
            margin: 1mm 0 1mm;
            line-height: 0;
        }

        .sprite-img {
            width: 12mm;
            height: 12mm;
            margin: 0 1mm;
        }

        .separator {
            border-top: 0.3mm solid #ddd;
            margin: 1.5mm 0;
        }

        .qr-code {
            width: 18mm;
            height: 18mm;
            margin: 1.5mm auto 1mm;
        }

        .short-tag {
            font-size: 9pt;
            font-family: 'Courier New', Courier, monospace;
            letter-spacing: 1.5pt;
            color: #333;
            margin: 1mm 0;
        }

        .screen-name {
            font-size: 10pt;
            color: #333;
            margin: 1mm 0 0;
        }

        .full-name {
            font-size: 7.5pt;
            color: #777;
            margin: 0.5mm 0 0;
        }

        .base-url {
            font-size: 6.5pt;
            color: #aaa;
            margin: 0 3mm;
        }

        /* === Back panel styles (deck list) === */
        .decklist-header {
            font-size: 8pt;
            font-weight: bold;
            margin: 1mm 2mm 0.5mm;
            color: #1a1a1a;
            text-align: center;
        }

        .decklist-section {
            margin: 0 2mm;
            text-align: left;
        }

        .decklist-section-title {
            font-size: 6pt;
            font-weight: bold;
            text-transform: uppercase;
            color: #888;
            letter-spacing: 0.5pt;
            margin: 1mm 0 0.3mm;
            padding-top: 0.5mm;
            border-top: 0.2mm solid #eee;
        }

        .decklist-section-title:first-child {
            border-top: none;
            margin-top: 0;
            padding-top: 0;
        }

        .decklist-card {
            font-size: 5.5pt;
            line-height: 1.5;
            color: #333;
        }

        .decklist-qty {
            font-weight: bold;
            display: inline;
            color: #555;
        }

        .decklist-set {
            color: #999;
            font-size: 5pt;
        }

        .decklist-footer {
            font-size: 5pt;
            color: #aaa;
            text-align: center;
            margin-top: 1mm;
        }
    </style>
</head>
<body>
    <div class="page">
        {# Crop marks #}
        <div class="crop-h crop-top-l"></div>
        <div class="crop-h crop-top-r"></div>
        <div class="crop-h crop-bottom-l"></div>
        <div class="crop-h crop-bottom-r"></div>
        <div class="crop-v crop-vtl"></div>
        <div class="crop-v crop-vtr"></div>
        <div class="crop-v crop-vbl"></div>
        <div class="crop-v crop-vbr"></div>

        {# Fold line #}
        <div class="fold-line"></div>

        {# Front panel — label #}
        <div class="panel panel-front">
            <div class="deck-name">{{ deck.name }}</div>

            {% if spriteDataUris is not empty %}
                <div class="sprites">
                    {% for sprite in spriteDataUris %}
                        <img src="{{ sprite.dataUri }}" alt="{{ sprite.name }}" class="sprite-img">
                    {% endfor %}
                </div>
            {% endif %}

            <div class="separator"></div>

            <img src="{{ qrCodeDataUri }}" class="qr-code" alt="QR Code">

            <div class="short-tag">{{ deck.shortTag }}</div>

            <div class="separator"></div>

            <div class="screen-name">{{ deck.owner.screenName }}</div>
            <div class="full-name">{{ deck.owner.firstName }} {{ deck.owner.lastName }}</div>

            <div class="separator"></div>

            <div class="base-url">{{ baseUrl }}</div>
        </div>

        {# Back panel — deck list #}
        <div class="panel panel-back">
            <div class="decklist-header">{{ deck.name }}</div>

            {% for type, cards in groupedCards %}
                <div class="decklist-section">
                    <div class="decklist-section-title">
                        {% if type == 'pokemon' %}Pokémon
                        {% elseif type == 'trainer' %}Trainer
                        {% elseif type == 'energy' %}Energy
                        {% endif %}
                    </div>
                    {% for card in cards %}
                        <div class="decklist-card">
                            <span class="decklist-qty">{{ card.quantity }}</span> {{ card.cardName }} <span class="decklist-set">{{ card.setCode }} {{ card.cardNumber }}</span>
                        </div>
                    {% endfor %}
                </div>
            {% endfor %}

            <div class="decklist-footer">{{ deck.shortTag }}</div>
        </div>
    </div>
</body>
</html>
