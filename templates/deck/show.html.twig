{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% block canonical %}
    <link rel="canonical" href="{{ canonical_url('decks', 'app_deck_show', {short_tag: deck.shortTag}) }}">
{% endblock %}

{% block opengraph %}
    {% set og_title = deck.name ~ ' — ' ~ channel_param('brand_name', 'Expanded Decks') %}
    {% set og_url = canonical_url('decks', 'app_deck_show', {short_tag: deck.shortTag}) %}
    {% set og_type = 'article' %}
    {% set og_image = deck.currentVersion ? deck.currentVersion.mosaicImageUrl : null %}
    {% include '_partials/opengraph.html.twig' %}
{% endblock %}

{% block structured_data %}
    <script type="application/ld+json">{{ json_ld(structured_data().buildCreativeWork(deck, canonical_url('decks', 'app_deck_show', {short_tag: deck.shortTag}))) }}</script>
{% endblock %}

{% macro cardSection(label, cards) %}
    <div class="card shadow-sm">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ label }}</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-themed table-sm mb-0">
                <thead>
                    <tr>
                        <th style="width: 32px">{{ 'app.deck.table_qty'|trans }}</th>
                        <th>{{ 'app.deck.table_card'|trans }}</th>
                        <th style="width: 56px">{{ 'app.deck.table_set'|trans }}</th>
                        <th style="width: 40px">#</th>
                    </tr>
                </thead>
                <tbody>
                    {% for card in cards %}
                        <tr>
                            <td>{{ card.quantity }}</td>
                            <td>
                                {% if card.imageUrl %}
                                    <span class="card-hover" data-quantity="{{ card.quantity }}">
                                        {{ card.cardName }}
                                        <img class="card-hover-img" src="{{ card.imageUrl }}" alt="{{ card.cardName }}" onerror="this.style.display='none'">
                                    </span>
                                {% else %}
                                    {{ card.cardName }}
                                {% endif %}
                            </td>
                            <td><code>{{ card.setCode }}</code></td>
                            <td>{{ card.cardNumber }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endmacro %}

{% block title %}{{ deck.name }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block body %}
    {# Deck info — compact header #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><span class="badge bg-dark badge-short-id me-2">{{ deck.shortTag }}</span>{{ deck_sprites(deck) }}{{ deck.name }}</h5>
            <div class="d-flex align-items-center gap-2">
                {% if deck.status.value == 'lent' %}
                    <span class="badge badge-lent">{{ 'app.common.lent'|trans }}</span>
                {% elseif deck.status.value == 'retired' %}
                    <span class="badge badge-retired">{{ 'app.deck.badge_retired'|trans }}</span>
                {% endif %}
            </div>
        </div>
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <span><strong>{{ 'app.deck.owner'|trans }}</strong> {{ deck.owner.screenName }}</span>
                <span><strong>{{ 'app.deck.format'|trans }}</strong> {{ deck.format }}</span>
                {% if deck.currentVersion %}
                    <span><strong>{{ 'app.deck.version'|trans }}</strong> v{{ deck.currentVersion.versionNumber }}</span>
                {% endif %}
                {% if deck.archetype and deck.archetype.deletedAt is null %}
                    <span><strong>{{ 'app.deck.archetype_label'|trans }}</strong> {% if deck.archetype.published %}<a href="{{ feature_url('archetypes', 'app_archetype_show', {slug: deck.archetype.slug}) }}"{{ not current_channel().enableArchetypes ? ' target="_blank" rel="noopener"' }}>{{ deck.archetype.localizedName(app.request.locale) }}</a>{% else %}{{ deck.archetype.localizedName(app.request.locale) }}{% endif %}</span>
                {% endif %}
                {% if deck.languages is not empty %}
                    <span><strong>{{ 'app.deck.languages_label'|trans }}</strong> {{ deck.languages|join(', ') }}</span>
                {% endif %}
                {% if deck.notes %}
                    <span><strong>{{ 'app.deck.notes_label'|trans }}</strong> {{ deck.notes }}</span>
                {% endif %}

                <span class="ms-auto d-flex gap-2">
                    {% if isOwner %}
                        <a href="{{ path('app_deck_import', {id: deck.id}) }}" class="btn btn-sm btn-gold">{{ 'app.deck.import_list'|trans }}</a>
                    {% endif %}
                    {% if isOwner or (versionCount > 1) or is_granted('ROLE_TECHNICAL_ADMIN') %}
                        <div class="dropdown">
                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                {% if versionCount > 1 %}
                                    <li><a class="dropdown-item" href="{{ path('app_deck_versions', {short_tag: deck.shortTag}) }}">{{ 'app.deck.version_history'|trans }}</a></li>
                                {% endif %}
                                {% if isOwner %}
                                    <li><a class="dropdown-item" href="{{ path('app_deck_edit', {id: deck.id}) }}">{{ 'app.common.edit'|trans }}</a></li>
                                    <li><a class="dropdown-item" href="{{ path('app_deck_label_pdf', {short_tag: deck.shortTag}) }}" target="_blank">{{ 'app.deck.label_pdf'|trans }}</a></li>
                                    {% if deck.currentVersion %}
                                        <li><a class="dropdown-item" href="{{ path('app_deck_label_foldable_pdf', {short_tag: deck.shortTag}) }}" target="_blank">{{ 'app.deck.label_foldable_pdf'|trans }}</a></li>
                                    {% endif %}
                                    {% if deck.status.value != 'lent' %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <form method="post" action="{{ path('app_deck_toggle_retired', {id: deck.id}) }}">
                                                <input type="hidden" name="_token" value="{{ csrf_token('deck-toggle-retired-' ~ deck.id) }}">
                                                {% if deck.status.value == 'retired' %}
                                                    <button type="submit" class="dropdown-item">{{ 'app.deck.reactivate'|trans }}</button>
                                                {% else %}
                                                    {% if activeBorrowCount > 0 %}
                                                        <button type="submit" class="dropdown-item" onclick="return confirm('{{ 'app.deck.confirm_retire_with_borrows'|trans({'%count%': activeBorrowCount})|e('js') }}')">{{ 'app.deck.retire'|trans }}</button>
                                                    {% else %}
                                                        <button type="submit" class="dropdown-item" onclick="return confirm('{{ 'app.deck.confirm_retire'|trans|e('js') }}')">{{ 'app.deck.retire'|trans }}</button>
                                                    {% endif %}
                                                {% endif %}
                                            </form>
                                        </li>
                                    {% endif %}
                                    {% if deck.deletedAt is null and activeBorrowCount == 0 %}
                                        <li>
                                            <form method="post" action="{{ path('app_deck_delete', {id: deck.id}) }}" onsubmit="return confirm('{{ 'app.deck.delete_confirm'|trans|e('js') }}')">
                                                <input type="hidden" name="_token" value="{{ csrf_token('deck-delete-' ~ deck.id) }}">
                                                <button type="submit" class="dropdown-item text-danger">{{ 'app.deck.delete_button'|trans }}</button>
                                            </form>
                                        </li>
                                    {% endif %}
                                {% endif %}
                                {% if is_granted('ROLE_TECHNICAL_ADMIN') and deck.currentVersion %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form method="post" action="{{ path('app_deck_reenrich', {short_tag: deck.shortTag}) }}">
                                            <input type="hidden" name="_token" value="{{ csrf_token('deck-reenrich-' ~ deck.id) }}">
                                            <button type="submit" class="dropdown-item" onclick="return confirm('{{ 'app.deck.reenrich.confirm'|trans|e('js') }}')">
                                                {{ 'app.deck.reenrich.button'|trans }}
                                            </button>
                                        </form>
                                    </li>
                                {% endif %}
                            </ul>
                        </div>
                    {% endif %}
                </span>
            </div>
        </div>
    </div>

    {# Borrow activity card #}
    {% if app.user %}
        {% if eligibleEvents is not empty or deckBorrows is not empty %}
            <div class="card shadow-sm mb-3">
                <div class="card-header card-header-themed">
                    <h5 class="mb-0">{{ 'app.deck.borrow_activity'|trans }}</h5>
                </div>
                <div class="card-body">
                    {% if eligibleEvents is not empty %}
                        <form method="post" action="{{ path('app_borrow_request') }}" class="mb-3">
                            <input type="hidden" name="deck_id" value="{{ deck.id }}">
                            <input type="hidden" name="redirect_to" value="deck">
                            <input type="hidden" name="_token" value="">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label for="borrow_event" class="form-label">{{ 'app.common.event'|trans }}</label>
                                    <select name="event_id" id="borrow_event" class="form-select form-select-sm" required>
                                        <option value="">{{ 'app.borrow.select_event'|trans }}</option>
                                        {% for event in eligibleEvents %}
                                            <option value="{{ event.id }}" data-token="{{ csrf_token('borrow-request-' ~ event.id) }}">
                                                {{ event.name }} ({{ event.date|user_date(event.timezone) }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label for="borrow_notes_deck" class="form-label">{{ 'app.borrow.notes_label'|trans }}</label>
                                    <input type="text" name="notes" id="borrow_notes_deck" class="form-control form-control-sm" placeholder="{{ 'app.borrow.notes_placeholder'|trans }}">
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-sm btn-primary w-100">{{ 'app.borrow.request_button'|trans }}</button>
                                </div>
                            </div>
                        </form>
                        <script>
                            document.getElementById('borrow_event').addEventListener('change', function() {
                                var selected = this.options[this.selectedIndex];
                                var token = selected.getAttribute('data-token') || '';
                                this.closest('form').querySelector('input[name="_token"]').value = token;
                            });
                        </script>
                    {% endif %}

                    {% if deckBorrows is not empty %}
                        {% include 'borrow/_activity_list.html.twig' with {
                            borrows: deckBorrows,
                            columns: ['event', 'borrower', 'status', 'date']
                        } only %}

                        {% if totalBorrowCount > deckBorrows|length %}
                            <div class="text-center mt-2">
                                <a href="{{ path('app_deck_borrow_history', {short_tag: deck.shortTag}) }}" class="btn btn-sm btn-outline-secondary">
                                    {{ 'app.deck.see_more_activity'|trans({'%count%': totalBorrowCount}) }}
                                </a>
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% endif %}

    {# Event status overview — owner only #}
    {% if isOwner and eventStatusOverview is not empty %}
        <div class="card shadow-sm mb-3">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.deck.event_status_overview'|trans }}</h5>
            </div>
            <div class="card-body p-0">
                {# Desktop table (md+) #}
                <div class="table-responsive d-none d-md-block">
                    <table class="table table-striped table-themed table-sm mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.common.event'|trans }}</th>
                                <th>{{ 'app.common.date'|trans }}</th>
                                <th>{{ 'app.common.status'|trans }}</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for entry in eventStatusOverview %}
                                <tr>
                                    <td><a href="{{ path('app_event_show', {id: entry.event.id}) }}">{{ entry.event.name }}</a></td>
                                    <td>{{ entry.event.date|user_date(entry.event.timezone) }}</td>
                                    <td>
                                        {% if entry.status.value == 'played' %}
                                            <span class="badge bg-success">{{ 'app.deck.event_status.played'|trans }}</span>
                                        {% elseif entry.status.value == 'actively_borrowed' %}
                                            <span class="badge bg-primary">{{ 'app.deck.event_status.actively_borrowed'|trans }}</span>
                                        {% elseif entry.status.value == 'delegated_to_staff' %}
                                            <span class="badge bg-info">{{ 'app.deck.event_status.delegated_to_staff'|trans }}</span>
                                        {% elseif entry.status.value == 'registered' %}
                                            <span class="badge bg-warning">{{ 'app.deck.event_status.registered'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ 'app.deck.event_status.not_registered'|trans }}</span>
                                        {% endif %}
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
                {# Mobile cards (<md) #}
                <div class="d-md-none">
                    {% for entry in eventStatusOverview %}
                        <div class="p-3 {{ not loop.last ? 'border-bottom' : '' }}">
                            <div class="d-flex justify-content-between align-items-start">
                                <div>
                                    <a href="{{ path('app_event_show', {id: entry.event.id}) }}">{{ entry.event.name }}</a>
                                    <div class="text-muted small">{{ entry.event.date|user_date(entry.event.timezone) }}</div>
                                </div>
                                {% if entry.status.value == 'played' %}
                                    <span class="badge bg-success">{{ 'app.deck.event_status.played'|trans }}</span>
                                {% elseif entry.status.value == 'actively_borrowed' %}
                                    <span class="badge bg-primary">{{ 'app.deck.event_status.actively_borrowed'|trans }}</span>
                                {% elseif entry.status.value == 'delegated_to_staff' %}
                                    <span class="badge bg-info">{{ 'app.deck.event_status.delegated_to_staff'|trans }}</span>
                                {% elseif entry.status.value == 'registered' %}
                                    <span class="badge bg-warning">{{ 'app.deck.event_status.registered'|trans }}</span>
                                {% else %}
                                    <span class="badge bg-secondary">{{ 'app.deck.event_status.not_registered'|trans }}</span>
                                {% endif %}
                            </div>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>
    {% endif %}

    {# Card list — React island with variant toggle, mosaic, and copy #}
    {% if deck.currentVersion and groupedCards|length > 0 %}
        {# Warning: cards matched by name only (Japanese/unrecognized set codes) #}
        {% set allCards = [] %}
        {% for type, cards in groupedCards %}
            {% set allCards = allCards|merge(cards) %}
        {% endfor %}
        {% set nameMatchedCards = [] %}
        {% for card in allCards %}
            {% if card.imageUrl is not null and card.cardPrinting is null and card.cardType != 'energy' %}
                {% set nameMatchedCards = nameMatchedCards|merge([card]) %}
            {% endif %}
        {% endfor %}
        {% if nameMatchedCards|length > 0 %}
            <div class="alert alert-warning mb-2">
                <strong>{{ 'app.deck.name_match_warning_title'|trans }}</strong>
                {{ 'app.deck.name_match_warning_body'|trans }}
                <ul class="mb-0 mt-1">
                    {% for card in nameMatchedCards %}
                        <li>{{ card.cardName }} ({{ card.setCode }} {{ card.cardNumber }})</li>
                    {% endfor %}
                </ul>
            </div>
        {% endif %}

        {# Serialize card data for React island #}
        {% macro serializeCards(groupedCards) %}
            {% set serialized = {} %}
            {% for type, cards in groupedCards %}
                {% set cardList = [] %}
                {% for card in cards %}
                    {% set cardList = cardList|merge([{
                        cardName: card.cardName,
                        quantity: card.quantity,
                        setCode: card.setCode,
                        cardNumber: card.cardNumber,
                        cardType: card.cardType,
                        trainerSubtype: card.trainerSubtype,
                        imageUrl: card.imageUrl,
                    }]) %}
                {% endfor %}
                {% set serialized = serialized|merge({(type): cardList}) %}
            {% endfor %}
            {{ serialized|json_encode }}
        {% endmacro %}

        <div id="deck-card-list-root"
             data-original-cards="{{ _self.serializeCards(groupedCards)|trim }}"
             data-minified-cards="{{ _self.serializeCards(minifiedGroupedCards)|trim }}"
             data-mosaic-url="{{ deck.currentVersion.mosaicImageUrl is not null ? deck.currentVersion.mosaicImageUrl : '' }}"
             data-mosaic-url-null="{{ deck.currentVersion.mosaicImageUrl is null ? '1' : '' }}"
             data-minified-mosaic-url="{{ deck.currentVersion.minifiedMosaicImageUrl is not null ? deck.currentVersion.minifiedMosaicImageUrl : '' }}"
             data-minified-mosaic-url-null="{{ deck.currentVersion.minifiedMosaicImageUrl is null ? '1' : '' }}"
             data-raw-list="{{ formattedOriginalList|e('html_attr') }}"
             data-minified-list="{{ deck.currentVersion.minifiedList is not null ? deck.currentVersion.minifiedList|e('html_attr') : '' }}"
             data-minified-list-null="{{ deck.currentVersion.minifiedList is null ? '1' : '' }}"
             data-deck-name="{{ deck.name }}"
             data-label-variant-original="{{ 'app.deck.variant_original'|trans }}"
             data-label-variant-minified="{{ 'app.deck.variant_minified'|trans }}"
             data-label-view-table="{{ 'app.deck.view_table'|trans }}"
             data-label-view-mosaic="{{ 'app.deck.view_mosaic'|trans }}"
             data-label-copy-button="{{ 'app.deck.export_copy_button'|trans }}"
             data-label-copied="{{ 'app.deck.export_copied'|trans }}"
             data-label-share-mosaic="{{ 'app.deck.share_mosaic'|trans }}"
             data-label-mosaic-alt="{{ 'app.deck.mosaic_alt'|trans({'%name%': deck.name}) }}"
             data-label-section-pokemon="{{ 'app.deck.section_pokemon'|trans }}"
             data-label-section-trainer="{{ 'app.deck.section_trainer'|trans }}"
             data-label-section-energy="{{ 'app.deck.section_energy'|trans }}"
             data-label-table-qty="{{ 'app.deck.table_qty'|trans }}"
             data-label-table-card="{{ 'app.deck.table_card'|trans }}"
             data-label-table-set="{{ 'app.deck.table_set'|trans }}"
             data-label-name-match-warning-title="{{ 'app.deck.name_match_warning_title'|trans }}"
             data-label-name-match-warning-body="{{ 'app.deck.name_match_warning_body'|trans }}"
             data-cardmarket-wishlist="{{ cardmarketWishlist is not null ? cardmarketWishlist|e('html_attr') : '' }}"
             data-label-copy-cardmarket="{{ 'app.deck.export_copy_cardmarket'|trans }}"
             data-label-copy-cardmarket-tooltip="{{ 'app.deck.export_copy_cardmarket_tooltip'|trans }}"
             data-label-mosaic-generating="{{ 'app.deck.mosaic_generating'|trans }}"
             data-label-minified-generating="{{ 'app.deck.minified_generating'|trans }}">
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-3">{{ 'app.deck.no_list'|trans }}</p>
                {% if app.user and isOwner %}
                    <a href="{{ path('app_deck_import', {id: deck.id}) }}" class="btn btn-gold">{{ 'app.deck.import_cta'|trans }}</a>
                {% endif %}
            </div>
        </div>
    {% endif %}

    {# Borrow login CTA — discreet prompt for anonymous visitors #}
    {% if not app.user %}
        <p class="text-center text-muted small mt-3">
            {{ 'app.deck.borrow_login_cta'|trans }}
            <a href="{{ path('app_login', {'_target_path': app.request.requestUri}) }}">{{ 'app.deck.login_cta'|trans }}</a>
            /
            <a href="{{ path('app_register', {'_target_path': app.request.requestUri}) }}">{{ 'app.deck.register_cta'|trans|lower }}</a>.
        </p>
    {% endif %}

    {# "Found this deck" button — visible to non-owners, placed at bottom of page #}
    {% if not isOwner %}
        <div id="deck-found-root"
             data-api-url="{{ path('app_deck_found_report', {short_tag: deck.shortTag}) }}"
             data-csrf-token="{{ csrf_token('deck-found-' ~ deck.shortTag) }}"
             data-is-logged-in="{{ app.user ? '1' : '' }}"
             data-owner-discord="{{ deck.owner.discordUsername ?? '' }}"
             data-sitekey="{{ friendly_captcha_sitekey }}"
             data-labels="{{ {
                 button: 'app.deck.found_button'|trans,
                 title: 'app.deck.found_modal_title'|trans,
                 anonymousLabel: 'app.deck.found_anonymous_label'|trans,
                 messageLabel: 'app.deck.found_message_label'|trans,
                 messagePlaceholder: 'app.deck.found_message_placeholder'|trans,
                 discordCopy: 'app.deck.found_discord_copy'|trans,
                 discordCopied: 'app.deck.found_discord_copied'|trans,
                 submit: 'app.deck.found_submit'|trans,
                 success: 'app.deck.found_success'|trans,
                 error: 'app.deck.found_error'|trans,
             }|json_encode|e('html_attr') }}"
        ></div>
    {% endif %}

{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('deck_card_list') }}
    {% if not isOwner %}
        {{ encore_entry_link_tags('deck_found') }}
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('deck_card_list') }}
    {% if not isOwner %}
        {{ encore_entry_script_tags('deck_found') }}
    {% endif %}
{% endblock %}
