{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% macro cardSection(label, cards) %}
    <div class="card shadow-sm">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ label }}</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-striped table-themed table-sm mb-0">
                <thead>
                    <tr>
                        <th style="width: 32px">{{ 'app.deck.table_qty'|trans }}</th>
                        <th>{{ 'app.deck.table_card'|trans }}</th>
                        <th style="width: 56px">{{ 'app.deck.table_set'|trans }}</th>
                        <th style="width: 40px">#</th>
                    </tr>
                </thead>
                <tbody>
                    {% for card in cards %}
                        <tr>
                            <td>{{ card.quantity }}</td>
                            <td>
                                {% if card.imageUrl %}
                                    <span class="card-hover">
                                        {{ card.cardName }}
                                        <img class="card-hover-img" src="{{ card.imageUrl }}" alt="{{ card.cardName }}">
                                    </span>
                                {% else %}
                                    {{ card.cardName }}
                                {% endif %}
                            </td>
                            <td><code>{{ card.setCode }}</code></td>
                            <td>{{ card.cardNumber }}</td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endmacro %}

{% block title %}{{ deck.name }} — Expanded Decks{% endblock %}

{% block body %}
    {# Deck info — compact header #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><span class="badge bg-dark me-2">{{ deck.shortTag }}</span>{{ deck.name }}</h5>
            <div class="d-flex align-items-center gap-2">
                {% if deck.status.value == 'lent' %}
                    <span class="badge badge-lent">{{ 'app.deck.badge_lent'|trans }}</span>
                {% elseif deck.status.value == 'retired' %}
                    <span class="badge badge-retired">{{ 'app.deck.badge_retired'|trans }}</span>
                {% endif %}
            </div>
        </div>
        <div class="card-body py-2">
            <div class="d-flex flex-wrap align-items-center gap-3">
                <span><strong>{{ 'app.deck.owner'|trans }}</strong> {{ deck.owner.screenName }}</span>
                <span><strong>{{ 'app.deck.format'|trans }}</strong> {{ deck.format }}</span>
                {% if deck.currentVersion %}
                    <span><strong>{{ 'app.deck.version'|trans }}</strong> v{{ deck.currentVersion.versionNumber }}</span>
                {% endif %}
                {% if deck.archetype %}
                    <span><strong>{{ 'app.deck.archetype_label'|trans }}</strong> {{ deck.archetype.name }}</span>
                {% endif %}
                {% if deck.languages is not empty %}
                    <span><strong>{{ 'app.deck.languages_label'|trans }}</strong> {{ deck.languages|join(', ') }}</span>
                {% endif %}
                {% if deck.notes %}
                    <span><strong>{{ 'app.deck.notes_label'|trans }}</strong> {{ deck.notes }}</span>
                {% endif %}

                <span class="ms-auto d-flex gap-2">
                    {% if isOwner %}
                        <a href="{{ path('app_deck_edit', {id: deck.id}) }}" class="btn btn-sm btn-outline-primary">{{ 'app.common.edit'|trans }}</a>
                        <a href="{{ path('app_deck_import', {id: deck.id}) }}" class="btn btn-sm btn-gold">{{ 'app.deck.import_list'|trans }}</a>
                    {% endif %}
                </span>
            </div>
        </div>
    </div>

    {# Borrow activity card #}
    {% if app.user %}
        {% if eligibleEvents is not empty or deckBorrows is not empty %}
            <div class="card shadow-sm mb-3">
                <div class="card-header card-header-themed">
                    <h5 class="mb-0">{{ 'app.deck.borrow_activity'|trans }}</h5>
                </div>
                <div class="card-body">
                    {% if eligibleEvents is not empty %}
                        <form method="post" action="{{ path('app_borrow_request') }}" class="mb-3">
                            <input type="hidden" name="deck_id" value="{{ deck.id }}">
                            <input type="hidden" name="redirect_to" value="deck">
                            <input type="hidden" name="_token" value="">
                            <div class="row g-2 align-items-end">
                                <div class="col-md-5">
                                    <label for="borrow_event" class="form-label">{{ 'app.borrow.event_label'|trans }}</label>
                                    <select name="event_id" id="borrow_event" class="form-select form-select-sm" required>
                                        <option value="">{{ 'app.borrow.select_event'|trans }}</option>
                                        {% for event in eligibleEvents %}
                                            <option value="{{ event.id }}" data-token="{{ csrf_token('borrow-request-' ~ event.id) }}">
                                                {{ event.name }} ({{ event.date|user_date }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                </div>
                                <div class="col-md-5">
                                    <label for="borrow_notes_deck" class="form-label">{{ 'app.borrow.notes_label'|trans }}</label>
                                    <input type="text" name="notes" id="borrow_notes_deck" class="form-control form-control-sm" placeholder="{{ 'app.borrow.notes_placeholder'|trans }}">
                                </div>
                                <div class="col-md-2">
                                    <button type="submit" class="btn btn-sm btn-primary w-100">{{ 'app.borrow.request_button'|trans }}</button>
                                </div>
                            </div>
                        </form>
                        <script>
                            document.getElementById('borrow_event').addEventListener('change', function() {
                                var selected = this.options[this.selectedIndex];
                                var token = selected.getAttribute('data-token') || '';
                                this.closest('form').querySelector('input[name="_token"]').value = token;
                            });
                        </script>
                    {% endif %}

                    {% if deckBorrows is not empty %}
                        <div class="table-responsive">
                            <table class="table table-striped table-themed table-sm mb-0">
                                <thead>
                                    <tr>
                                        <th>{{ 'app.borrow.table.event'|trans }}</th>
                                        <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                        <th>{{ 'app.borrow.table.status'|trans }}</th>
                                        <th>{{ 'app.borrow.table.date'|trans }}</th>
                                        <th></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    {% for borrow in deckBorrows %}
                                        <tr>
                                            <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                                            <td>{{ borrow.borrower.screenName }}</td>
                                            <td>{{ borrowBadge(borrow) }}</td>
                                            <td>{{ borrow.requestedAt|user_date }}</td>
                                            <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                        </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endif %}
                </div>
            </div>
        {% endif %}
    {% else %}
        <div class="card shadow-sm mb-3">
            <div class="card-body text-center py-4">
                <p class="mb-2">{{ 'app.deck.borrow_login_cta'|trans }}</p>
                <a href="{{ path('app_login', {'_target_path': app.request.requestUri}) }}" class="btn btn-primary me-2">{{ 'app.deck.login_cta'|trans }}</a>
                <a href="{{ path('app_register', {'_target_path': app.request.requestUri}) }}" class="btn btn-outline-secondary">{{ 'app.deck.register_cta'|trans }}</a>
            </div>
        </div>
    {% endif %}

    {# Card list — 2 columns on md+, energy under the shortest column #}
    {% if deck.currentVersion and groupedCards|length > 0 %}
        {% set pokemonCards = groupedCards.pokemon|default([]) %}
        {% set trainerCards = groupedCards.trainer|default([]) %}
        {% set energyCards = groupedCards.energy|default([]) %}
        {% set energyInLeft = pokemonCards|length <= trainerCards|length %}

        <div class="row">
            {# Left column: Pokemon + Energy if pokemon is shorter #}
            <div class="col-md-6 mb-3">
                {% if pokemonCards|length > 0 %}
                    {{ _self.cardSection('app.deck.section_pokemon'|trans, pokemonCards) }}
                {% endif %}
                {% if energyInLeft and energyCards|length > 0 %}
                    <div class="mt-3">
                        {{ _self.cardSection('app.deck.section_energy'|trans, energyCards) }}
                    </div>
                {% endif %}
            </div>

            {# Right column: Trainer + Energy if trainer is shorter #}
            <div class="col-md-6 mb-3">
                {% if trainerCards|length > 0 %}
                    {{ _self.cardSection('app.deck.section_trainer'|trans, trainerCards) }}
                {% endif %}
                {% if not energyInLeft and energyCards|length > 0 %}
                    <div class="mt-3">
                        {{ _self.cardSection('app.deck.section_energy'|trans, energyCards) }}
                    </div>
                {% endif %}
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body text-center py-5">
                <p class="text-muted mb-3">{{ 'app.deck.no_list'|trans }}</p>
                {% if app.user and isOwner %}
                    <a href="{{ path('app_deck_import', {id: deck.id}) }}" class="btn btn-gold">{{ 'app.deck.import_cta'|trans }}</a>
                {% endif %}
            </div>
        </div>
    {% endif %}

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('deck_show') }}
{% endblock %}
