{% extends 'base.html.twig' %}

{% block title %}{{ 'app.deck.new_title'|trans }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header card-header-themed">
                    <h5 class="mb-0">{{ 'app.deck.new_title'|trans }}</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_row(form.name) }}
                        {{ form_row(form.notes) }}

                        {# Archetype — React island #}
                        <div class="mb-3">
                            <label class="form-label">{{ 'app.deck.archetype_optional'|trans }}</label>
                            <div id="archetype-select-root"
                                 data-search-url="{{ path('app_archetype_search') }}"
                                 data-create-url="{{ path('app_archetype_create') }}"
                            ></div>
                            {{ form_widget(form.archetype) }}
                        </div>

                        {# Languages — React island #}
                        <div class="mb-3">
                            <label class="form-label">{{ 'app.deck.languages_label'|trans }}</label>
                            <div id="language-select-root"></div>
                            {{ form_widget(form.languages) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.public) }}
                        </div>

                        {# Deck list — optional inline import (F2.13) #}
                        <div class="mb-3">
                            <label class="form-label" for="{{ form.rawList.vars.id }}">
                                {{ 'app.deck.deck_list_label'|trans }} <small class="text-muted">{{ 'app.deck.deck_list_optional'|trans }}</small>
                            </label>
                            {{ form_widget(form.rawList, {attr: {class: 'form-control font-monospace'}}) }}
                            <div class="form-text">{{ 'app.deck.deck_list_help'|trans }}</div>
                        </div>

                        <button type="submit" class="btn btn-gold w-100">{{ 'app.deck.create_button'|trans }}</button>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('deck_form') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('deck_form') }}
{% endblock %}
