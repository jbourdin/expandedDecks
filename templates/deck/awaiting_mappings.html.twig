{% extends 'base.html.twig' %}

{% block title %}{{ deck.name }} — {{ 'app.deck.awaiting_mappings.title'|trans }}{% endblock %}

{% block body %}
    <div class="text-center py-5">
        <div class="spinner-border text-primary mb-3" role="status">
            <span class="visually-hidden">{{ 'app.common.loading'|trans }}</span>
        </div>
        <h3>{{ 'app.deck.awaiting_mappings.heading'|trans }}</h3>
        <p class="text-muted">{{ 'app.deck.awaiting_mappings.message'|trans }}</p>
        <meta http-equiv="refresh" content="10">
    </div>
{% endblock %}
