{% extends 'base.html.twig' %}

{% block title %}{{ deck.name }} — {{ 'app.deck.awaiting_mappings.title'|trans }}{% endblock %}

{% block body %}
    <div class="text-center py-5">
        <i class="bi bi-exclamation-triangle fs-1 text-warning mb-3 d-block"></i>
        <h3>{{ 'app.deck.awaiting_mappings.heading'|trans }}</h3>
        <p class="text-muted">{{ 'app.deck.awaiting_mappings.message'|trans }}</p>
    </div>
{% endblock %}
