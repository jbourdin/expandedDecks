{% extends 'base.html.twig' %}

{% block title %}{{ 'app.deck.catalog_title'|trans }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.deck.catalog_title'|trans }}</h1>
        {% if is_granted('ROLE_USER') %}
            <a href="{{ path('app_deck_new') }}" class="btn btn-gold">{{ 'app.deck.new_deck'|trans }}</a>
        {% endif %}
    </div>

    {# Filter bar #}
    {% set hasActiveFilters = (filters.archetype ?? '') != '' or (filters.event ?? 0) > 0 or (filters.owner ?? 0) > 0 %}
    <form method="get" action="{{ path('app_deck_list') }}" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label for="filter-search" class="form-label">{{ 'app.common.search'|trans }}</label>
                    <input type="text" id="filter-search" name="q" class="form-control" placeholder="{{ 'app.deck.search_placeholder'|trans }}" value="{{ filters.search ?? '' }}">
                </div>

                {# Toggle button for extra filters — visible only on mobile #}
                <div class="col-12 d-md-none">
                    <button class="btn btn-sm btn-outline-secondary w-100" type="button" data-bs-toggle="collapse" data-bs-target="#catalog-extra-filters">
                        {{ 'app.deck.more_filters'|trans }}
                        {% if hasActiveFilters %}<span class="badge bg-primary ms-1">{{ 'app.common.active'|trans }}</span>{% endif %}
                    </button>
                </div>

                {# Extra filters: always visible on md+, collapsible on mobile #}
                <div class="col-12 col-md-auto flex-md-grow-1 collapse d-md-block {{ hasActiveFilters ? 'show' : '' }}" id="catalog-extra-filters">
                    <div class="row g-2 align-items-end">
                        <div class="col-md-4">
                            <label class="form-label">{{ 'app.deck.archetype_filter'|trans }}</label>
                            <div data-catalog-archetype
                                 data-search-url="{{ path('app_archetype_search') }}"
                                 data-hidden-input="archetype"
                                 data-placeholder="Search archetype..."
                                 {% if (filters.archetype ?? '') != '' %}
                                     data-initial-value="{{ archetypeName }}"
                                     data-initial-id="{{ filters.archetype }}"
                                 {% endif %}
                            ></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ 'app.deck.event_filter'|trans }}</label>
                            <div data-catalog-event
                                 data-search-url="{{ path('app_event_search') }}"
                                 data-hidden-input="event"
                                 data-placeholder="Search event..."
                                 {% if (filters.event ?? 0) > 0 %}
                                     data-initial-value="{{ eventName }}"
                                     data-initial-id="{{ filters.event }}"
                                 {% endif %}
                            ></div>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label">{{ 'app.deck.owner_filter'|trans }}</label>
                            <div data-catalog-owner
                                 data-search-url="{{ path('app_deck_owner_search') }}"
                                 data-hidden-input="owner"
                                 data-placeholder="Search owner..."
                                 {% if (filters.owner ?? 0) > 0 %}
                                     data-initial-value="{{ ownerName }}"
                                     data-initial-id="{{ filters.owner }}"
                                 {% endif %}
                            ></div>
                        </div>
                    </div>
                </div>

                <div class="col-md-2 d-flex gap-2">
                    <button type="submit" class="btn btn-gold">{{ 'app.common.filter'|trans }}</button>
                    <a href="{{ path('app_deck_list') }}" class="btn btn-outline-secondary">{{ 'app.common.clear'|trans }}</a>
                </div>
            </div>
        </div>
    </form>

    {# Result count #}
    <p class="text-muted mb-3">{{ 'app.deck.results_count'|trans({'%count%': totalItems}) }}</p>

    {% if totalItems > 0 %}
        {# Card grid #}
        <div class="row">
            {% for deck in decks %}
                <div class="col-sm-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm">
                        <div class="card-body">
                            <h5 class="card-title">
                                <span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>
                                {% if deck.archetype %}{{ archetype_sprites(deck.archetype) }} {% endif %}<a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}">{{ deck.name }}</a>
                            </h5>
                            <p class="card-text mb-1">
                                {{ 'app.deck.owner'|trans }} <a href="{{ path('app_deck_list', filters|merge({owner: deck.owner.id})) }}">{{ deck.owner.screenName }}</a>
                            </p>
                            {% if deck.archetype %}
                                <p class="card-text mb-0">
                                    {{ 'app.deck.archetype_label'|trans }} <a href="{{ path('app_deck_list', filters|merge({archetype: deck.archetype.slug})) }}">{{ deck.archetype.name }}</a>
                                </p>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        {# Pagination #}
        {% if totalPages > 1 %}
            <nav>
                <ul class="pagination justify-content-center">
                    <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_deck_list', filters|merge({page: currentPage - 1})) }}">{{ 'app.common.previous'|trans }}</a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item {% if p == currentPage %}active{% endif %}">
                            <a class="page-link" href="{{ path('app_deck_list', filters|merge({page: p})) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_deck_list', filters|merge({page: currentPage + 1})) }}">{{ 'app.common.next'|trans }}</a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="alert alert-info">{{ 'app.deck.no_results'|trans }}</div>
    {% endif %}
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('catalog_filters') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('catalog_filters') }}
{% endblock %}
