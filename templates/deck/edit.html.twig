{% extends 'base.html.twig' %}

{% block title %}Edit {{ deck.name }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header card-header-themed">
                    <h5 class="mb-0">Edit {{ deck.name }}</h5>
                </div>
                <div class="card-body">
                    {{ form_start(form) }}
                        {{ form_row(form.name) }}
                        {{ form_row(form.notes) }}

                        {# Archetype — React island #}
                        <div class="mb-3">
                            <label class="form-label">Archetype (optional)</label>
                            <div id="archetype-select-root"
                                 data-search-url="{{ path('app_archetype_search') }}"
                                 data-create-url="{{ path('app_archetype_create') }}"
                                 {% if deck.archetype %}
                                     data-archetype-id="{{ deck.archetype.id }}"
                                     data-archetype-name="{{ deck.archetype.name }}"
                                 {% endif %}
                            ></div>
                            {{ form_widget(form.archetype) }}
                        </div>

                        {# Languages — React island #}
                        <div class="mb-3">
                            <label class="form-label">Languages</label>
                            <div id="language-select-root"
                                 {% if deck.languages is not empty %}
                                     data-languages="{{ deck.languages|json_encode }}"
                                 {% endif %}
                            ></div>
                            {{ form_widget(form.languages) }}
                        </div>

                        <div class="mb-3">
                            {{ form_row(form.public) }}
                            {% if has_active_registrations is defined and has_active_registrations %}
                                <div class="form-text text-warning">This deck has active event registrations and cannot be unpublished.</div>
                            {% endif %}
                        </div>

                        <button type="submit" class="btn btn-gold w-100">Save Changes</button>
                    {{ form_end(form) }}

                    <a href="{{ path('app_deck_show', {id: deck.id}) }}" class="btn btn-outline-secondary w-100 mt-2">Cancel</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('deck_form') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('deck_form') }}
{% endblock %}
