<!DOCTYPE html>
<html lang="{{ app.request.locale }}">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <title>{% block title %}{{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}</title>
        <link rel="icon" href="/favicon.svg" type="image/svg+xml">
        {% block canonical %}{% endblock %}
        <meta property="og:locale" content="{{ app.request.locale == 'fr' ? 'fr_FR' : 'en_US' }}">
        {% if current_channel().locales|length > 1 %}
            <meta property="og:locale:alternate" content="{{ app.request.locale == 'fr' ? 'en_US' : 'fr_FR' }}">
        {% endif %}
        {% block meta %}{% endblock %}
        {% block structured_data %}{% endblock %}
        {% block stylesheets %}
            {% if channel_theme() %}
                {{ encore_entry_link_tags('theme_' ~ channel_theme()) }}
            {% else %}
                {{ encore_entry_link_tags('app') }}
            {% endif %}
        {% endblock %}
    </head>
    <body>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-pokemon">
            <div class="container">
                <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">{{ channel_param('brand_name', 'Expanded Decks') }}</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto align-items-end align-items-lg-center">
                        {% set channel = current_channel() %}
                        {% if app.user %}
                            {% if channel.enableDecks %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_dashboard') }}">{{ 'app.nav.dashboard'|trans }}</a>
                                </li>
                            {% endif %}
                            {% for category in menu_categories() %}
                                {% set pages = category.pages|filter(p => p.published)|sort((a, b) => a.position <=> b.position) %}
                                {% if pages|length == 1 %}
                                    <li class="nav-item">
                                        <a class="nav-link" href="{{ path('app_page_show', {slug: pages|first.slug}) }}">{{ category.getName(app.request.locale) }}</a>
                                    </li>
                                {% elseif pages|length > 1 %}
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">{{ category.getName(app.request.locale) }}</a>
                                        <ul class="dropdown-menu">
                                            {% for page in pages|slice(0, 5) %}
                                                <li><a class="dropdown-item" href="{{ path('app_page_show', {slug: page.slug}) }}">{{ page.getTitle(app.request.locale) }}</a></li>
                                            {% endfor %}
                                            {% if pages|length > 5 %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item" href="{{ path('app_page_category', {id: category.id}) }}">{{ 'app.common.see_all'|trans }}</a></li>
                                            {% endif %}
                                        </ul>
                                    </li>
                                {% endif %}
                            {% endfor %}
                            {% if channel.enableArchetypes %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_archetype_list') }}">{{ 'app.nav.archetypes'|trans }}</a>
                                </li>
                            {% endif %}
                            {% if channel.enableDecks %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_deck_list') }}">{{ 'app.nav.decks'|trans }}</a>
                                </li>
                            {% endif %}
                            {% if channel.enableEvents %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_event_list') }}">{{ 'app.nav.events'|trans }}</a>
                                </li>
                            {% endif %}
                            {% if channel.enableDecks %}
                                <li class="nav-item d-flex align-items-center me-2">
                                    <div id="notification-bell-root"
                                         data-api-url="{{ path('app_notification_api_list') }}"
                                         data-list-url="{{ path('app_notification_list') }}"
                                         data-mark-read-url-template="{{ path('app_notification_api_mark_read', {id: 0})|replace({'0': '__ID__'}) }}"
                                         data-mark-all-read-url="{{ path('app_notification_api_mark_all_read') }}"
                                         data-label-mark-read="{{ 'app.notification.center.mark_read'|trans }}"
                                         data-label-mark-all-read="{{ 'app.notification.center.mark_all_read'|trans }}"
                                         data-label-view-all="{{ 'app.notification.center.view_all'|trans }}"
                                         data-label-empty="{{ 'app.notification.center.empty'|trans }}">
                                    </div>
                                </li>
                            {% endif %}
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle nav-link-user d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <img src="{{ gravatar(app.user.email, 64) }}" alt="" width="32" height="32" class="rounded-circle me-1">
                                    {{ app.user.screenName }}
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    {% if channel.enableDecks %}
                                        <li><a class="dropdown-item" href="{{ path('app_dashboard') }}">{{ 'app.nav.dashboard'|trans }}</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_deck_list', {owner: app.user.id}) }}">{{ 'app.nav.my_decks'|trans }}</a></li>
                                    {% endif %}
                                    <li><a class="dropdown-item" href="{{ path('app_profile_edit') }}">{{ 'app.nav.profile'|trans }}</a></li>
                                    {% if channel.enableDecks %}
                                        <li><a class="dropdown-item" href="{{ path('app_profile_notifications') }}">{{ 'app.nav.notifications'|trans }}</a></li>
                                    {% endif %}
                                    {% if is_granted('ROLE_ADMIN') %}
                                        <li><hr class="dropdown-divider"></li>
                                        <li><a class="dropdown-item" href="{{ path('app_admin_user_list') }}">{{ 'app.nav.admin_users'|trans }}</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_admin_channel_list') }}">{{ 'app.nav.admin_channels'|trans }}</a></li>
                                    {% endif %}
                                    {% if is_granted('ROLE_ARCHETYPE_EDITOR') %}
                                        {% if not is_granted('ROLE_ADMIN') %}
                                            <li><hr class="dropdown-divider"></li>
                                        {% endif %}
                                        <li><a class="dropdown-item" href="{{ path('app_admin_archetype_list') }}">{{ 'app.nav.admin_archetypes'|trans }}</a></li>
                                    {% endif %}
                                    {% if is_granted('ROLE_TECHNICAL_ADMIN') %}
                                        {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_ARCHETYPE_EDITOR') %}
                                            <li><hr class="dropdown-divider"></li>
                                        {% endif %}
                                        <li><a class="dropdown-item" href="{{ path('app_admin_technical_dashboard') }}">{{ 'app.nav.admin_technical'|trans }}</a></li>
                                    {% endif %}
                                    {% if is_granted('ROLE_CMS_EDITOR') %}
                                        {% if not is_granted('ROLE_ADMIN') and not is_granted('ROLE_ARCHETYPE_EDITOR') and not is_granted('ROLE_TECHNICAL_ADMIN') %}
                                            <li><hr class="dropdown-divider"></li>
                                        {% endif %}
                                        <li><a class="dropdown-item" href="{{ path('app_admin_homepage_editor') }}">{{ 'app.nav.homepage_editor'|trans }}</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_admin_page_list') }}">{{ 'app.nav.cms_pages'|trans }}</a></li>
                                        <li><a class="dropdown-item" href="{{ path('app_admin_menu_category_list') }}">{{ 'app.nav.cms_categories'|trans }}</a></li>
                                    {% endif %}
                                    <li><hr class="dropdown-divider"></li>
                                    <li><a class="dropdown-item" href="{{ path('app_logout') }}">{{ 'app.nav.logout'|trans }}</a></li>
                                </ul>
                            </li>
                        {% else %}
                            {% for category in menu_categories() %}
                                {% set pages = category.pages|filter(p => p.published)|sort((a, b) => a.position <=> b.position) %}
                                {% if pages|length == 1 %}
                                    <li class="nav-item">
                                        <a class="nav-link" href="{{ path('app_page_show', {slug: pages|first.slug}) }}">{{ category.getName(app.request.locale) }}</a>
                                    </li>
                                {% elseif pages|length > 1 %}
                                    <li class="nav-item dropdown">
                                        <a class="nav-link dropdown-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">{{ category.getName(app.request.locale) }}</a>
                                        <ul class="dropdown-menu">
                                            {% for page in pages|slice(0, 5) %}
                                                <li><a class="dropdown-item" href="{{ path('app_page_show', {slug: page.slug}) }}">{{ page.getTitle(app.request.locale) }}</a></li>
                                            {% endfor %}
                                            {% if pages|length > 5 %}
                                                <li><hr class="dropdown-divider"></li>
                                                <li><a class="dropdown-item" href="{{ path('app_page_category', {id: category.id}) }}">{{ 'app.common.see_all'|trans }}</a></li>
                                            {% endif %}
                                        </ul>
                                    </li>
                                {% endif %}
                            {% endfor %}
                            {% if channel.enableArchetypes %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_archetype_list') }}">{{ 'app.nav.archetypes'|trans }}</a>
                                </li>
                            {% endif %}
                            {% if channel.enableDecks %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_deck_list') }}">{{ 'app.nav.decks'|trans }}</a>
                                </li>
                            {% endif %}
                            {% if channel.enableEvents %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_event_list') }}">{{ 'app.nav.events'|trans }}</a>
                                </li>
                            {% endif %}
                            <li class="nav-item">
                                <a class="nav-link" href="{{ path('app_login', {'_target_path': app.request.pathInfo}) }}">{{ 'app.nav.login'|trans }}</a>
                            </li>
                            {% if channel.enableRegister %}
                                <li class="nav-item">
                                    <a class="nav-link" href="{{ path('app_register', {'_target_path': app.request.pathInfo}) }}">{{ 'app.nav.register'|trans }}</a>
                                </li>
                            {% endif %}
                        {% endif %}
                        {% if current_channel().locales|length > 1 %}
                            {% set currentLocale = app.request.locale %}
                            {% set alternateLocale = currentLocale == 'en' ? 'fr' : 'en' %}
                            {% set routeParams = app.request.attributes.get('_route_params', {}) %}
                            {% if '_locale' in routeParams|keys %}
                                {% set switchUrl = path(app.request.attributes.get('_route'), routeParams|merge({_locale: alternateLocale})) %}
                            {% else %}
                                {% set switchUrl = path('app_locale_switch', {_locale: alternateLocale, _redirect: app.request.requestUri}) %}
                            {% endif %}
                            <li class="nav-item d-flex align-items-center ms-lg-2">
                                {% if currentLocale == 'en' %}
                                    <span class="fw-bold text-light small">EN</span>
                                    <span class="mx-1 text-secondary">|</span>
                                    <a href="{{ switchUrl }}" class="text-light text-decoration-none small" aria-label="{{ 'app.nav.switch_to_french'|trans }}">FR</a>
                                {% else %}
                                    <a href="{{ switchUrl }}" class="text-light text-decoration-none small" aria-label="{{ 'app.nav.switch_to_english'|trans }}">EN</a>
                                    <span class="mx-1 text-secondary">|</span>
                                    <span class="fw-bold text-light small">FR</span>
                                {% endif %}
                            </li>
                        {% endif %}
                    </ul>
                </div>
            </div>
        </nav>

        <main class="container py-4">
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div class="alert alert-{{ label }} alert-dismissible fade show">
                        {{ message }}
                        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                    </div>
                {% endfor %}
            {% endfor %}

            {% block body %}{% endblock %}
        </main>

        <footer class="footer-pokemon py-4 mt-auto">
            <div class="container">
                {% set footerCategories = footer_categories() %}
                {% if footerCategories is not empty %}
                    <div class="row mb-3">
                        {% for category in footerCategories %}
                            {% set pages = category.pages|filter(p => p.published)|sort((a, b) => a.position <=> b.position) %}
                            {% if pages is not empty %}
                                <div class="col-sm-4 col-md-3">
                                    <h6 class="text-uppercase mb-2">{{ category.getName(app.request.locale) }}</h6>
                                    <ul class="list-unstyled">
                                        {% for page in pages %}
                                            <li class="mb-1"><a href="{{ path('app_page_show', {slug: page.slug}) }}">{{ page.getTitle(app.request.locale) }}</a></li>
                                        {% endfor %}
                                    </ul>
                                </div>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <hr class="my-2">
                {% endif %}
                <div class="text-center">
                    {{ channel_param('copyright_footer', '&copy; ' ~ "now"|date("Y") ~ ' ' ~ channel_param('brand_name', 'Expanded Decks'))|raw }}
                    <span class="ms-2" style="font-size: 0.75rem;">{{ app_version }}</span>
                    <span class="ms-2">·</span>
                    <a href="https://github.com/jbourdin/expandedDecks" class="ms-1" target="_blank" rel="noopener">GitHub</a>
                </div>
            </div>
        </footer>

        {% block javascripts %}
            {{ encore_entry_script_tags('app') }}
            {% if app.user and channel is defined and channel.enableDecks %}
                {{ encore_entry_script_tags('notification_bell') }}
                {{ encore_entry_link_tags('notification_bell') }}
            {% endif %}
            <script>
                {# Preserve scroll position across form-driven page reloads #}
                (function() {
                    var key = 'ed_scroll_' + location.pathname;
                    var saved = sessionStorage.getItem(key);
                    if (saved) {
                        sessionStorage.removeItem(key);
                        window.scrollTo(0, parseInt(saved, 10));
                    }
                    document.querySelectorAll('form[method="post"]').forEach(function(form) {
                        form.addEventListener('submit', function() {
                            sessionStorage.setItem(key, String(window.scrollY));
                        });
                    });
                })();
            </script>
        {% endblock %}
    </body>
</html>
