{% extends 'base.html.twig' %}
{% from 'borrow/_status_badge.html.twig' import badge as borrowBadge %}

{% block title %}{{ 'app.dashboard.title'|trans }}{% endblock %}

{% block body %}
    <h1 class="mb-4">{{ 'app.dashboard.welcome'|trans({'%name%': user.screenName}) }}</h1>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">{{ 'app.dashboard.my_decks'|trans }}</h5>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_deck_list', {owner: user.id}) }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
                        <a href="{{ path('app_deck_new') }}" class="btn btn-sm btn-gold">{{ 'app.common.new'|trans }}</a>
                    </div>
                </div>
                <div class="card-body">
                    {% if ownedDecks|length > 0 %}
                        <ul class="list-group list-group-flush">
                            {% for deck in ownedDecks %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{{ deck.name }}</a>
                                    {% if deck.status.value == 'lent' %}
                                        <span class="badge badge-lent">{{ 'app.dashboard.badge_lent'|trans }}</span>
                                    {% elseif deck.status.value == 'retired' %}
                                        <span class="badge badge-retired">{{ 'app.dashboard.badge_retired'|trans }}</span>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">{{ 'app.dashboard.no_decks'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">{{ 'app.dashboard.my_events'|trans }}</h5>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_event_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <a href="{{ path('app_event_new') }}" class="btn btn-sm btn-gold">{{ 'app.common.new'|trans }}</a>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    {% if myEvents|length > 0 %}
                        <ul class="list-group list-group-flush">
                            {% for event in myEvents %}
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong><a href="{{ path('app_event_show', {id: event.id}) }}">{{ event.name }}</a></strong>
                                        <br>
                                        <small class="text-muted">
                                            {% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone, date_only: true} %}
                                            {% if event.location %} &mdash; {{ event.location }}{% endif %}
                                        </small>
                                    </div>
                                    {% set engagement = event.engagementFor(user) %}
                                    {% if engagement %}
                                        {% if engagement.state.value == 'registered_playing' %}
                                            <span class="badge bg-success">{{ 'app.dashboard.badge_playing'|trans }}</span>
                                        {% elseif engagement.state.value == 'registered_spectating' %}
                                            <span class="badge bg-info">{{ 'app.dashboard.badge_spectating'|trans }}</span>
                                        {% elseif engagement.state.value == 'invited' %}
                                            <span class="badge bg-warning text-dark">{{ 'app.dashboard.badge_invited'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ 'app.dashboard.badge_interested'|trans }}</span>
                                        {% endif %}
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">{{ 'app.dashboard.no_events'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% if staffingEvents|length > 0 %}
        <div class="card mb-4">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.dashboard.staffing'|trans }}</h5>
            </div>
            <ul class="list-group list-group-flush">
                {% for event in staffingEvents %}
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <strong><a href="{{ path('app_event_show', {id: event.id}) }}">{{ event.name }}</a></strong>
                            <br>
                            <small class="text-muted">
                                {% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone, date_only: true} %}
                                {% if event.location %} &mdash; {{ event.location }}{% endif %}
                            </small>
                        </div>
                        {% if event.organizer == user %}
                            <span class="badge bg-primary">{{ 'app.dashboard.badge_organizer'|trans }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ 'app.dashboard.badge_staff'|trans }}</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.dashboard.recent_borrow_activity'|trans }}</h5>
            <a href="{{ path('app_borrow_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
        </div>
        <div class="card-body">
            {% if recentBorrows|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-themed mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                <th>{{ 'app.borrow.table.event'|trans }}</th>
                                <th>{{ 'app.borrow.table.status'|trans }}</th>
                                <th>{{ 'app.borrow.table.date'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for borrow in recentBorrows %}
                                <tr>
                                    <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}</a></td>
                                    <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                                    <td>{{ borrowBadge(borrow) }}</td>
                                    <td>{{ borrow.requestedAt|user_date }}</td>
                                    <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">{{ 'app.dashboard.no_borrow_activity'|trans }}</p>
            {% endif %}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.dashboard.recent_lend_activity'|trans }}</h5>
            <a href="{{ path('app_lend_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
        </div>
        <div class="card-body">
            {% if recentLends|length > 0 %}
                <div class="table-responsive">
                    <table class="table table-striped table-themed mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                <th>{{ 'app.borrow.table.event'|trans }}</th>
                                <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                <th>{{ 'app.borrow.table.status'|trans }}</th>
                                <th>{{ 'app.borrow.table.date'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for borrow in recentLends %}
                                <tr>
                                    <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}</a></td>
                                    <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                                    <td>{{ borrow.borrower.screenName }}</td>
                                    <td>{{ borrowBadge(borrow) }}</td>
                                    <td>{{ borrow.requestedAt|user_date }}</td>
                                    <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            {% else %}
                <p class="text-muted mb-0">{{ 'app.dashboard.no_lend_activity'|trans }}</p>
            {% endif %}
        </div>
    </div>

    {% if is_granted('ROLE_ORGANIZER') or recentManagedBorrows|length > 0 %}
        <div class="card">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.dashboard.event_management_activity'|trans }}</h5>
            </div>
            <div class="card-body">
                {% if recentManagedBorrows|length > 0 %}
                    <div class="table-responsive">
                        <table class="table table-striped table-themed mb-0">
                            <thead>
                                <tr>
                                    <th>{{ 'app.borrow.table.deck'|trans }}</th>
                                    <th>{{ 'app.borrow.table.borrower'|trans }}</th>
                                    <th>{{ 'app.borrow.table.event'|trans }}</th>
                                    <th>{{ 'app.borrow.table.status'|trans }}</th>
                                    <th>{{ 'app.borrow.table.date'|trans }}</th>
                                    <th></th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for borrow in recentManagedBorrows %}
                                    <tr>
                                        <td><a href="{{ path('app_deck_show', {short_tag: borrow.deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ borrow.deck.shortTag }}</span>{{ borrow.deck.name }}</a></td>
                                        <td>{{ borrow.borrower.screenName }}</td>
                                        <td><a href="{{ path('app_event_show', {id: borrow.event.id}) }}">{{ borrow.event.name }}</a></td>
                                        <td>{{ borrowBadge(borrow) }}</td>
                                        <td>{{ borrow.requestedAt|user_date }}</td>
                                        <td><a href="{{ path('app_borrow_show', {id: borrow.id}) }}" class="btn btn-sm btn-outline-secondary">{{ 'app.common.view'|trans }}</a></td>
                                    </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% else %}
                    <p class="text-muted mb-0">{{ 'app.dashboard.no_management_activity'|trans }}</p>
                {% endif %}
            </div>
        </div>
    {% endif %}
{% endblock %}
