{% extends 'base.html.twig' %}

{% block title %}{{ 'app.dashboard.title'|trans }}{% endblock %}

{% block body %}
    <h1 class="mb-4">{{ 'app.dashboard.welcome'|trans({'%name%': user.screenName}) }}</h1>

    {% if stats is defined %}
        <h5 class="text-muted mb-2">{{ 'app.dashboard.stats.global_title'|trans }}</h5>
        <div class="row mb-4">
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-md-0">
                <a href="{{ path('app_deck_list') }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-primary">{{ stats.totalDecks }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.total_decks'|trans }}</small>
                    </div>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-md-0">
                <a href="{{ path('app_lend_list') }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-success">{{ stats.activeBorrows }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.active_borrows'|trans }}</small>
                    </div>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-sm-0">
                <a href="{{ path('app_event_list') }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-info">{{ stats.upcomingEvents }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.upcoming_events'|trans }}</small>
                    </div>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <a href="{{ path('app_lend_list', {status: 'overdue'}) }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold {{ stats.overdueReturns > 0 ? 'text-danger' : 'text-secondary' }}">{{ stats.overdueReturns }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.overdue_returns'|trans }}</small>
                    </div>
                </a>
            </div>
        </div>
    {% endif %}

    {% if myStats is defined %}
        <h5 class="text-muted mb-2">{{ 'app.dashboard.stats.my_events_title'|trans }}</h5>
        <div class="row mb-4">
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-md-0">
                <div class="card text-center shadow-sm h-100">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-primary">{{ myStats.registeredDecks }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.registered_decks'|trans }}</small>
                    </div>
                </div>
            </div>
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-md-0">
                <a href="{{ path('app_lend_list', {scope: 'managed'}) }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-success">{{ myStats.activeBorrows }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.active_borrows'|trans }}</small>
                    </div>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-3 mb-3 mb-sm-0">
                <a href="{{ path('app_event_list', {scope: 'staffing'}) }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold text-info">{{ myStats.upcomingEvents }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.upcoming_events'|trans }}</small>
                    </div>
                </a>
            </div>
            <div class="col-12 col-sm-6 col-md-3">
                <a href="{{ path('app_lend_list', {scope: 'managed', status: 'overdue'}) }}" class="card text-center shadow-sm h-100 text-decoration-none">
                    <div class="card-body py-3">
                        <div class="fs-2 fw-bold {{ myStats.overdueReturns > 0 ? 'text-danger' : 'text-secondary' }}">{{ myStats.overdueReturns }}</div>
                        <small class="text-muted">{{ 'app.dashboard.stats.overdue_returns'|trans }}</small>
                    </div>
                </a>
            </div>
        </div>
    {% endif %}

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">{{ 'app.dashboard.my_decks'|trans }}</h5>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_deck_list', {owner: user.id}) }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
                        <a href="{{ path('app_deck_new') }}" class="btn btn-sm btn-gold">{{ 'app.common.new'|trans }}</a>
                    </div>
                </div>
                <div class="card-body">
                    {% if ownedDecks|length > 0 %}
                        <ul class="list-group list-group-flush">
                            {% for deck in ownedDecks %}
                                <li class="list-group-item d-flex justify-content-between align-items-center">
                                    <a href="{{ path('app_deck_show', {short_tag: deck.shortTag}) }}"><span class="badge bg-dark badge-short-id me-1">{{ deck.shortTag }}</span>{{ deck.name }}</a>
                                    {% if deck.status.value == 'lent' %}
                                        <span class="badge badge-lent">{{ 'app.dashboard.badge_lent'|trans }}</span>
                                    {% elseif deck.status.value == 'retired' %}
                                        <span class="badge badge-retired">{{ 'app.dashboard.badge_retired'|trans }}</span>
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">{{ 'app.dashboard.no_decks'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card h-100">
                <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
                    <h5 class="mb-0">{{ 'app.dashboard.my_events'|trans }}</h5>
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_event_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
                        {% if is_granted('ROLE_ORGANIZER') %}
                            <a href="{{ path('app_event_new') }}" class="btn btn-sm btn-gold">{{ 'app.common.new'|trans }}</a>
                        {% endif %}
                    </div>
                </div>
                <div class="card-body">
                    {% if myEvents|length > 0 %}
                        <ul class="list-group list-group-flush">
                            {% for event in myEvents %}
                                <li class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <strong><a href="{{ path('app_event_show', {id: event.id}) }}">{{ event.name }}</a></strong>
                                        <br>
                                        <small class="text-muted">
                                            {% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone, date_only: true} %}
                                            {% if event.location %} &mdash; {{ event.location }}{% endif %}
                                        </small>
                                    </div>
                                    {% set engagement = event.engagementFor(user) %}
                                    {% if engagement %}
                                        {% if engagement.state.value == 'registered_playing' %}
                                            <span class="badge bg-success">{{ 'app.dashboard.badge_playing'|trans }}</span>
                                        {% elseif engagement.state.value == 'registered_spectating' %}
                                            <span class="badge bg-info">{{ 'app.dashboard.badge_spectating'|trans }}</span>
                                        {% elseif engagement.state.value == 'invited' %}
                                            <span class="badge bg-warning text-dark">{{ 'app.dashboard.badge_invited'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-secondary">{{ 'app.dashboard.badge_interested'|trans }}</span>
                                        {% endif %}
                                    {% endif %}
                                </li>
                            {% endfor %}
                        </ul>
                    {% else %}
                        <p class="text-muted mb-0">{{ 'app.dashboard.no_events'|trans }}</p>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {% if staffingEvents|length > 0 %}
        <div class="card mb-4">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.dashboard.staffing'|trans }}</h5>
            </div>
            <ul class="list-group list-group-flush">
                {% for event in staffingEvents %}
                    <li class="list-group-item d-flex justify-content-between align-items-start">
                        <div>
                            <strong><a href="{{ path('app_event_show', {id: event.id}) }}">{{ event.name }}</a></strong>
                            <br>
                            <small class="text-muted">
                                {% include 'event/_datetime.html.twig' with {dt: event.date, tz: event.timezone, date_only: true} %}
                                {% if event.location %} &mdash; {{ event.location }}{% endif %}
                            </small>
                        </div>
                        {% if event.organizer == user %}
                            <span class="badge bg-primary">{{ 'app.dashboard.badge_organizer'|trans }}</span>
                        {% else %}
                            <span class="badge bg-secondary">{{ 'app.dashboard.badge_staff'|trans }}</span>
                        {% endif %}
                    </li>
                {% endfor %}
            </ul>
        </div>
    {% endif %}

    <div class="card mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.dashboard.recent_borrow_activity'|trans }}</h5>
            <a href="{{ path('app_borrow_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
        </div>
        <div class="card-body">
            {% include 'borrow/_activity_list.html.twig' with {
                borrows: recentBorrows,
                columns: ['deck', 'event', 'status', 'date'],
                emptyMessage: 'app.dashboard.no_borrow_activity'|trans
            } only %}
        </div>
    </div>

    <div class="card mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.dashboard.recent_lend_activity'|trans }}</h5>
            <a href="{{ path('app_lend_list') }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
        </div>
        <div class="card-body">
            {% include 'borrow/_activity_list.html.twig' with {
                borrows: recentLends,
                columns: ['deck', 'event', 'borrower', 'status', 'date'],
                emptyMessage: 'app.dashboard.no_lend_activity'|trans
            } only %}
        </div>
    </div>

    {% if is_granted('ROLE_ORGANIZER') or recentManagedBorrows|length > 0 %}
        <div class="card">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.dashboard.event_management_activity'|trans }}</h5>
            </div>
            <div class="card-body">
                {% include 'borrow/_activity_list.html.twig' with {
                    borrows: recentManagedBorrows,
                    columns: ['deck', 'borrower', 'event', 'status', 'date'],
                    emptyMessage: 'app.dashboard.no_management_activity'|trans
                } only %}
            </div>
        </div>
    {% endif %}
{% endblock %}
