{% extends 'base.html.twig' %}

{% block title %}{{ 'app.home.title'|trans }}{% endblock %}

{% block body %}
    <div class="hero-pokemon p-5 mb-4">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold hero-title">{{ 'app.home.hero_title'|trans }}</h1>
            <p class="col-md-8 fs-4 hero-text">{{ 'app.home.hero_text'|trans }}</p>
            <div class="d-flex gap-2">
                <a href="{{ path('app_register', {'_target_path': app.request.requestUri}) }}" class="btn btn-gold btn-lg">{{ 'app.nav.register'|trans }}</a>
                <a href="{{ path('app_login', {'_target_path': app.request.requestUri}) }}" class="btn btn-outline-light-gold btn-lg">{{ 'app.nav.login'|trans }}</a>
            </div>
        </div>
    </div>

    {% if welcomeHtml is defined and welcomeHtml is not null %}
        <div class="card shadow-sm mb-4">
            <div class="card-body cms-content">
                {{ welcomeHtml|raw }}
            </div>
        </div>
    {% endif %}

    <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
        <div class="col">
            <div class="card shadow-sm h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center py-5">
                    <h2 class="display-6 fw-bold mb-1">{{ upcomingEventCount }}</h2>
                    <p class="text-muted mb-3">{{ 'app.home.upcoming_events'|trans({'%count%': upcomingEventCount}) }}</p>
                    <div>
                        <a href="{{ path('app_event_list') }}" class="btn btn-primary">{{ 'app.home.browse_events'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center py-5">
                    <h2 class="display-6 fw-bold mb-1">{{ publicDeckCount }}</h2>
                    <p class="text-muted mb-3">{{ 'app.home.decks_in_library'|trans({'%count%': publicDeckCount}) }}</p>
                    <div>
                        <a href="{{ path('app_deck_list') }}" class="btn btn-primary">{{ 'app.home.browse_library'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {% if newsPages is defined and newsPages is not empty %}
        <div class="card shadow-sm">
            <div class="card-header card-header-themed">
                <h5 class="mb-0">{{ 'app.home.latest_news'|trans }}</h5>
            </div>
            <div class="card-body p-0">
                {% for newsPage in newsPages %}
                    <div class="p-3 {{ not loop.last ? 'border-bottom' : '' }}">
                        <h6 class="mb-1">
                            <a href="{{ path('app_page_show', {slug: newsPage.slug}) }}">{{ newsPage.getTitle(locale) }}</a>
                        </h6>
                        <small class="text-muted">{{ newsPage.createdAt|date('Y-m-d') }}</small>
                    </div>
                {% endfor %}
            </div>
        </div>
    {% endif %}
{% endblock %}
