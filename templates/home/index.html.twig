{% extends 'base.html.twig' %}

{% block title %}Expanded Decks — Shared Pokemon TCG Deck Library{% endblock %}

{% block body %}
    <div class="hero-pokemon p-5 mb-4">
        <div class="container-fluid py-3">
            <h1 class="display-5 fw-bold hero-title">Expanded Decks</h1>
            <p class="col-md-8 fs-4 hero-text">A shared library of physical Pokemon TCG decks for the Expanded format. Browse available decks, borrow them for events, and manage your collection.</p>
            <div class="d-flex gap-2">
                <a href="{{ path('app_register', {'_target_path': app.request.requestUri}) }}" class="btn btn-gold btn-lg">Register</a>
                <a href="{{ path('app_login', {'_target_path': app.request.requestUri}) }}" class="btn btn-outline-light-gold btn-lg">Login</a>
            </div>
        </div>
    </div>

    <div class="row row-cols-1 row-cols-md-2 g-4">
        <div class="col">
            <div class="card shadow-sm h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center py-5">
                    <h2 class="display-6 fw-bold mb-1">{{ upcomingEventCount }}</h2>
                    <p class="text-muted mb-3">upcoming {{ upcomingEventCount == 1 ? 'event' : 'events' }}</p>
                    <div>
                        <a href="{{ path('app_event_list') }}" class="btn btn-primary">Browse events</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col">
            <div class="card shadow-sm h-100 text-center">
                <div class="card-body d-flex flex-column justify-content-center py-5">
                    <h2 class="display-6 fw-bold mb-1">{{ publicDeckCount }}</h2>
                    <p class="text-muted mb-3">{{ publicDeckCount == 1 ? 'deck' : 'decks' }} in the library</p>
                    <div>
                        <a href="{{ path('app_deck_list') }}" class="btn btn-primary">Browse the library</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}
