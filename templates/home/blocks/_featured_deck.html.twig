{# @see docs/features.md F10.4 — Homepage rendering service and Twig block partials #}
{% set deck = entry.resolvedData.deck|default(null) %}
{% set url = entry.resolvedData.url|default(null) %}
{% set mosaicUrl = entry.resolvedData.mosaicUrl|default(null) %}
{% set descriptionHtml = entry.resolvedData.descriptionHtml|default(null) %}

{% if deck is not null %}
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="d-flex align-items-center mb-2">
                {% if deck.archetype %}
                    <span class="me-2">{{ archetype_sprites(deck.archetype) }}</span>
                {% endif %}
                <div>
                    <h5 class="card-title mb-0">{{ deck.name }}</h5>
                    {% if deck.archetype %}
                        <small class="text-muted">{{ deck.archetype.localizedName(app.request.locale) }}</small>
                    {% endif %}
                </div>
            </div>
            {% if mosaicUrl %}
                <a href="{{ url }}" class="d-block mb-2">
                    <img src="{{ mosaicUrl }}" alt="{{ deck.name }}" class="img-fluid rounded w-100">
                </a>
            {% endif %}
            {% if descriptionHtml %}
                <div class="cms-content small">{{ descriptionHtml|raw }}</div>
            {% endif %}
            <a href="{{ url }}" class="btn btn-primary btn-sm mt-2">{{ 'app.homepage.view_deck'|trans }}</a>
        </div>
    </div>
{% endif %}
