{# @see docs/features.md F10.4 — Homepage rendering service and Twig block partials #}
{% set count = entry.resolvedData.count|default(0) %}
{% set title = entry.translations.title|default('app.home.upcoming_events'|trans({'%count%': count})) %}
{% set description = entry.translations.description|default('app.home.browse_events'|trans) %}

<div class="card shadow-sm h-100 text-center">
    <div class="card-body d-flex flex-column justify-content-center py-5">
        <h2 class="display-6 fw-bold mb-1">{{ count }}</h2>
        <p class="text-muted mb-3">{{ title }}</p>
        <div>
            <a href="{{ path('app_event_list') }}" class="btn btn-primary">{{ description }}</a>
        </div>
    </div>
</div>
