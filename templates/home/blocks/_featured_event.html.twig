{# @see docs/features.md F10.4 — Homepage rendering service and Twig block partials #}
{% set event = entry.resolvedData.event|default(null) %}
{% set url = entry.resolvedData.url|default(null) %}
{% set descriptionHtml = entry.resolvedData.descriptionHtml|default(null) %}
{% set image = entry.settings.image|default(null) %}

{% if event is not null %}
    <div class="card shadow-sm h-100">
        <div class="card-body d-flex gap-3 align-items-start">
            {% if image %}
                <a href="{{ url }}" class="flex-shrink-0">
                    <img src="{{ image }}" alt="{{ event.name }}" style="width: 120px; height: auto; border-radius: 4px;">
                </a>
            {% endif %}
            <div>
                <h5 class="card-title mb-1">{{ event.name }}</h5>
                <p class="text-muted mb-2">
                    <i class="bi bi-calendar-event me-1"></i>{{ event.date|date('Y-m-d') }}
                    {% if event.location %}
                        <span class="ms-2"><i class="bi bi-geo-alt me-1"></i>{{ event.location }}</span>
                    {% endif %}
                </p>
                {% if descriptionHtml %}
                    <div class="cms-content small">{{ descriptionHtml|raw }}</div>
                {% endif %}
                <a href="{{ url }}" class="btn btn-primary btn-sm mt-2">{{ 'app.homepage.view_event'|trans }}</a>
            </div>
        </div>
    </div>
{% endif %}
