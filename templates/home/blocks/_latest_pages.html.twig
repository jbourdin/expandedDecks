{# @see docs/features.md F10.4 — Homepage rendering service and Twig block partials #}
{% set pages = entry.resolvedData.pages|default([]) %}
{% set totalCount = entry.resolvedData.totalCount|default(0) %}
{% set category = entry.resolvedData.category|default(null) %}
{% set locale = entry.resolvedData.locale|default(app.request.locale) %}
{% set limit = entry.settings.limit|default(5) %}

{% if pages is not empty %}
    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h5 class="mb-0">{{ 'app.home.latest_news'|trans }}</h5>
            <div class="d-flex align-items-center gap-2">
                {% if category is not null %}
                    <a href="{{ path('app_page_category_feed', {id: category.id}) }}" class="btn btn-sm btn-outline-light" title="{{ 'app.cms.feed.subscribe'|trans }}" aria-label="{{ 'app.cms.feed.subscribe'|trans }}">
                        <i class="bi bi-rss"></i>
                    </a>
                {% endif %}
                {% if totalCount > limit and category is not null %}
                    <a href="{{ path('app_page_category', {id: category.id}) }}" class="btn btn-sm btn-outline-light">{{ 'app.common.see_all'|trans }}</a>
                {% endif %}
            </div>
        </div>
        <div class="card-body p-0">
            {% for newsPage in pages %}
                <div class="p-3 {{ not loop.last ? 'border-bottom' : '' }}">
                    <h6 class="mb-1">
                        <a href="{{ path('app_page_show', {slug: newsPage.slug}) }}">{{ newsPage.getTitle(locale) }}</a>
                    </h6>
                    <small class="text-muted">{{ newsPage.createdAt|date('Y-m-d') }}</small>
                </div>
            {% endfor %}
        </div>
    </div>
{% endif %}
