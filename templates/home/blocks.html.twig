{# @see docs/features.md F10.4 — Homepage rendering service and Twig block partials #}
{% extends 'base.html.twig' %}

{% block title %}
    {%- set homepageTitle = pageTitle|default('') -%}
    {%- if homepageTitle -%}
        {{ homepageTitle }}
    {%- else -%}
        {{ channel_param('brand_name', 'Expanded Decks') }}
    {%- endif -%}
{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ self_canonical_url('app_home_localized', {_locale: 'en'}) }}">
{% endblock %}

{% block opengraph %}
    {% set og_title = (pageTitle|default('')) ?: channel_param('brand_name', 'Expanded Decks') %}
    {% set og_url = self_canonical_url('app_home') %}
    {% set og_image = (ogImage|default('')) ?: channel_param('og_default_image', '') %}
    {% set og_description = ogDescription|default('') %}
    {{ include('_partials/opengraph.html.twig') }}
{% endblock %}

{% block structured_data %}
    <script type="application/ld+json">{{ json_ld(structured_data().buildWebSite(self_canonical_url('app_home_localized', {_locale: 'en'}))) }}</script>
{% endblock %}

{% block body %}
    {% set rowOpen = false %}
    {% set rowWidth = 0 %}

    {% for homepageBlock in blocks %}
        {% set partial = '_' ~ homepageBlock.type.value|replace({R: '_r', P: '_p', D: '_d', E: '_e'}) %}
        {# Convert camelCase to snake_case for template name #}
        {% set templateMap = {
            hero: '_hero',
            richText: '_rich_text',
            pageEmbed: '_page_embed',
            carousel: '_carousel',
            latestPages: '_latest_pages',
            featuredDeck: '_featured_deck',
            featuredEvent: '_featured_event',
        } %}
        {% set partial = templateMap[homepageBlock.type.value] %}

        {# Carousel variants: render the variant-specific partial when the
         # renderer resolved a non-default variant. Unknown values fall back
         # to the slideshow per HomepageCarouselVariant::fromStringOrDefault.
         # @see https://github.com/jbourdin/expandedDecks/issues/553 #}
        {% if homepageBlock.type.value == 'carousel' and homepageBlock.resolvedData.variant|default('slideshow') == 'feature_grid' %}
            {% set partial = '_carousel_feature_grid' %}
        {% endif %}

        {% if homepageBlock.columnWidth is not null %}
            {# Grid block — check if we need to open a new row #}
            {% if not rowOpen %}
                <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
                {% set rowOpen = true %}
                {% set rowWidth = 0 %}
            {% endif %}

            {% if rowWidth + homepageBlock.columnWidth > 12 %}
                {# Close current row and start a new one #}
                </div>
                <div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
                {% set rowWidth = 0 %}
            {% endif %}

            <div class="col-md-{{ homepageBlock.columnWidth }} {{ homepageBlock.cssClasses }}">
                {{ include('home/blocks/' ~ partial ~ '.html.twig', {entry: homepageBlock}) }}
            </div>
            {% set rowWidth = rowWidth + homepageBlock.columnWidth %}
        {% else %}
            {# Full-width block — close any open row first #}
            {% if rowOpen %}
                </div>
                {% set rowOpen = false %}
                {% set rowWidth = 0 %}
            {% endif %}

            {% if homepageBlock.cssClasses is not null %}
                <div class="{{ homepageBlock.cssClasses }}">
                    {{ include('home/blocks/' ~ partial ~ '.html.twig', {entry: homepageBlock}) }}
                </div>
            {% else %}
                {{ include('home/blocks/' ~ partial ~ '.html.twig', {entry: homepageBlock}) }}
            {% endif %}
        {% endif %}
    {% endfor %}

    {# Close trailing row if needed #}
    {% if rowOpen %}
        </div>
    {% endif %}
{% endblock %}
