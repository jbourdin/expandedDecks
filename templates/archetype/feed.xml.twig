 #
 # RSS 2.0 feed of the most recently published archetype variants. Items
 # link to the archetype page anchored on the variant short tag. The comment
 # closes with a whitespace-trimming tag so the XML declaration stays at the
 # very first byte of the response (required by the XML spec).
 #
 # @see docs/features.md F21.2 — RSS feed of archetype variants
 -#}
<?xml version="1.0" encoding="UTF-8"?>
{%- set feedTitle = 'app.archetype.feed.title'|trans({'%brand%': channel_param('brand_name', 'Expanded Decks')}) %}
{%- set feedLink = url('app_archetype_list') %}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:media="http://search.yahoo.com/mrss/">
    <channel>
        <title>{{ feedTitle }}</title>
        <link>{{ feedLink }}</link>
        <atom:link href="{{ url('app_archetype_feed') }}" rel="self" type="application/rss+xml"/>
        <description>{{ 'app.archetype.feed.description'|trans({'%brand%': channel_param('brand_name', 'Expanded Decks')}) }}</description>
        <language>{{ locale }}</language>
        {{- include('_partials/feed_image.xml.twig', {imageTitle: feedTitle, imageLink: feedLink}) -}}
        {%- if items|length > 0 %}
        <lastBuildDate>{{ (items|first).publishedAt|date('r') }}</lastBuildDate>
        {%- endif %}
        {%- for item in items %}
        <item>
            <title>{{ item.title }}</title>
            <link>{{ item.url }}</link>
            <guid isPermaLink="true">{{ item.url }}</guid>
            <pubDate>{{ item.publishedAt|date('r') }}</pubDate>
            {%- if item.description is not empty %}
            <description>{{ item.description }}</description>
            {%- endif %}
            {%- if item.image %}
            <media:content url="{{ channel_absolute_url(item.image) }}" medium="image"/>
            {%- endif %}
            {# Interim hardcoded author until a real content-authoring model exists. #}
            <dc:creator>Luby</dc:creator>
        </item>
        {%- endfor %}
    </channel>
</rss>
