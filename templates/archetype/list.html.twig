{% extends 'base.html.twig' %}

{% block title %}{{ 'app.archetype.catalog_title'|trans }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ canonical_url('archetypes', 'app_archetype_list') }}">
{% endblock %}

{% block hreflang %}
    {% for locale in current_channel().locales %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ canonical_url('archetypes', 'app_archetype_list', {_locale: locale}) }}">
    {% endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ canonical_url('archetypes', 'app_archetype_list', {_locale: 'en'}) }}">
{% endblock %}

{% block opengraph %}
    {% set og_title = 'app.archetype.catalog_title'|trans ~ ' — ' ~ channel_param('brand_name', 'Expanded Decks') %}
    {% set og_url = canonical_url('archetypes', 'app_archetype_list') %}
    {{ include('_partials/opengraph.html.twig') }}
{% endblock %}

{% block structured_data %}
    {% set items = [] %}
    {% for row in results %}
        {% set items = items|merge([{name: row.archetype.localizedName(app.request.locale), url: canonical_url('archetypes', 'app_archetype_show', {slug: row.archetype.slug})}]) %}
    {% endfor %}
    <script type="application/ld+json">{{ json_ld(structured_data().buildCollectionPage('app.archetype.catalog_title'|trans, canonical_url('archetypes', 'app_archetype_list'), items)) }}</script>
{% endblock %}

{% block body %}
    <h1 class="mb-4">{{ 'app.archetype.catalog_title'|trans }}</h1>

    {# Filter / sort bar #}
    <div class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-6">
                    <label class="form-label">{{ 'app.archetype.filter_by_tag'|trans }}</label>
                    <div class="d-flex flex-wrap gap-1">
                        <a href="{{ path('app_archetype_list', {sort: currentSort}) }}" class="btn btn-sm {{ not showDrafts and currentTags|length == 0 ? 'btn-gold' : 'btn-outline-secondary' }}">
                            {{ 'app.common.all'|trans }}
                        </a>
                        {% for tag in allTags %}
                            {% set isActive = tag in currentTags %}
                            {% if isActive %}
                                {% set newTags = currentTags|filter(selectedTag => selectedTag != tag) %}
                            {% else %}
                                {% set newTags = currentTags|merge([tag]) %}
                            {% endif %}
                            <a href="{{ path('app_archetype_list', {tags: newTags, sort: currentSort}) }}" class="btn btn-sm {{ isActive ? 'btn-gold' : 'btn-outline-secondary' }}">
                                {{ tag }}
                            </a>
                        {% endfor %}
                        {% if is_granted('ROLE_ARCHETYPE_EDITOR') %}
                            <a href="{{ path('app_archetype_list', {drafts: 1}) }}" class="btn btn-sm {{ showDrafts ? 'btn-warning' : 'btn-outline-warning' }}">
                                <i class="bi bi-eye me-1"></i>{{ 'app.archetype.filter_drafts'|trans }}
                            </a>
                        {% endif %}
                    </div>
                </div>
                <div class="col-md-3 ms-auto">
                    <label class="form-label">{{ 'app.archetype.sort_by'|trans }}</label>
                    <select class="form-select form-select-sm" onchange="window.location.href=this.value">
                        <option value="{{ path('app_archetype_list', {tags: currentTags, sort: 'position'}) }}" {{ currentSort == 'position' ? 'selected' }}>
                            {{ 'app.archetype.sort_relevance'|trans }}
                        </option>
                        <option value="{{ path('app_archetype_list', {tags: currentTags, sort: 'name'}) }}" {{ currentSort == 'name' ? 'selected' }}>
                            {{ 'app.common.name'|trans }}
                        </option>
                        {% if current_channel().enableDecks %}
                            <option value="{{ path('app_archetype_list', {tags: currentTags, sort: 'decks'}) }}" {{ currentSort == 'decks' ? 'selected' }}>
                                {{ 'app.archetype.sort_decks'|trans }}
                            </option>
                        {% endif %}
                    </select>
                </div>
            </div>
        </div>
    </div>

    {# Result count #}
    <p class="text-muted mb-3">{{ 'app.archetype.results_count'|trans({'%count%': results|length}) }}</p>

    {% if results|length > 0 %}
        <div class="row">
            {% for row in results %}
                {% set archetype = row.archetype %}
                {% set deckCount = row.deckCount %}
                <div class="col-sm-6 col-lg-4 mb-4">
                    <div class="card h-100 shadow-sm position-relative">
                        <a href="{{ path('app_archetype_show', {slug: archetype.slug}) }}{{ showDrafts ? '?preview=true' : '' }}" class="text-decoration-none stretched-link">
                            <div class="card-body">
                                <h5 class="card-title mb-2">
                                    {{ archetype_sprites(archetype) }}
                                    {{ archetype.localizedName(app.request.locale) }}
                                    {% if showDrafts %}
                                        <span class="badge bg-warning text-dark ms-1">{{ 'app.cms.status.draft'|trans }}</span>
                                    {% endif %}
                                </h5>
                                {% if archetype.playstyleTags|length > 0 %}
                                    <div class="mb-2">
                                        {% for tag in archetype.playstyleTags %}
                                            <span class="badge bg-secondary">{{ tag }}</span>
                                        {% endfor %}
                                    </div>
                                {% endif %}
                                {% if current_channel().enableDecks %}
                                    <p class="card-text text-muted mb-0">
                                        {{ 'app.archetype.deck_count'|trans({'%count%': deckCount}) }}
                                    </p>
                                {% endif %}
                            </div>
                        </a>
                        {% if is_granted('ROLE_ARCHETYPE_EDITOR') %}
                            <div class="dropdown position-absolute top-0 end-0 mt-2 me-2" style="z-index: 2">
                                <button class="btn btn-sm btn-outline-secondary dropdown-toggle no-caret" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'app.common.actions'|trans }}">
                                    <i class="bi bi-three-dots-vertical"></i>
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" href="{{ path('app_admin_archetype_edit', {id: archetype.id}) }}"><i class="bi bi-pencil me-2"></i>{{ 'app.common.edit'|trans }}</a></li>
                                </ul>
                            </div>
                        {% endif %}
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        <div class="alert alert-info">{{ 'app.archetype.no_results'|trans }}</div>
    {% endif %}
{% endblock %}
