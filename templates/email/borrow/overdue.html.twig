<!DOCTYPE html>
<html lang="{{ locale }}">
<head>
    <meta charset="UTF-8">
</head>
<body style="font-family: Arial, sans-serif; line-height: 1.6; color: #333; max-width: 600px; margin: 0 auto; padding: 20px;">
    <h1 style="color: #e74c3c;">{{ 'app.email.borrow.overdue_heading'|trans({}, 'messages', locale) }}</h1>

    <p>{{ 'app.email.greeting'|trans({'%name%': recipient.screenName}, 'messages', locale) }}</p>

    <p>{{ 'app.email.borrow.overdue_body'|trans({'%deck%': borrow.deck.name, '%event%': borrow.event.name}, 'messages', locale) }}</p>

    <p>{{ 'app.email.borrow.overdue_action'|trans({}, 'messages', locale) }}</p>

    <p style="text-align: center; margin: 30px 0;">
        <a href="{{ borrowUrl }}"
           style="background-color: #e74c3c; color: #ffffff; padding: 12px 24px; text-decoration: none; border-radius: 5px; display: inline-block;">
            {{ 'app.email.borrow.view_borrow'|trans({}, 'messages', locale) }}
        </a>
    </p>

    <p>{{ 'app.email.link_fallback'|trans({}, 'messages', locale) }}</p>
    <p style="word-break: break-all; color: #666;">{{ borrowUrl }}</p>

    <hr style="border: none; border-top: 1px solid #eee; margin: 30px 0;">
    <p style="color: #999; font-size: 12px;">{{ 'app.email.footer'|trans({}, 'messages', locale) }}</p>
</body>
</html>
