{% extends 'base.html.twig' %}

{# Intro-page description when set, else a list-purpose default (F19.7). #}
{% set metaDescription = metaDescription|default(null) ?: 'app.staple_card.meta_description'|trans %}

{% block title %}{{ 'app.staple_card.public.title'|trans }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block canonical %}
    <link rel="canonical" href="{{ canonical_url('staple-cards', 'app_staple_card_list') }}">
{% endblock %}

{% block hreflang %}
    {% for locale in current_channel().locales %}
        <link rel="alternate" hreflang="{{ locale }}" href="{{ canonical_url('staple-cards', 'app_staple_card_list', {_locale: locale}) }}">
    {% endfor %}
    <link rel="alternate" hreflang="x-default" href="{{ canonical_url('staple-cards', 'app_staple_card_list', {_locale: 'en'}) }}">
{% endblock %}

{% block opengraph %}
    {% set og_title = 'app.staple_card.public.title'|trans ~ ' — ' ~ channel_param('brand_name', 'Expanded Decks') %}
    {% set og_url = canonical_url('staple-cards', 'app_staple_card_list') %}
    {% set og_image = ogImage %}
    {% set og_description = ogDescription %}
    {{ include('_partials/opengraph.html.twig') }}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('staple_card_list') }}
{% endblock %}

{% block body %}
    <article class="card shadow-sm mb-4">
        <div class="card-header card-header-themed d-flex justify-content-between align-items-center">
            <h1 class="mb-0 h3">{{ 'app.staple_card.public.title'|trans }}</h1>
            {% if introPage and is_granted('ROLE_CMS_EDITOR') %}
                <a href="{{ path('app_admin_page_edit', {id: introPage.id}) }}" class="btn btn-sm btn-outline-light-gold">
                    <i class="bi bi-pencil me-1"></i>{{ 'app.common.edit'|trans }}
                </a>
            {% endif %}
        </div>
        {% if introHtml %}
            <div class="card-body cms-content">{{ introHtml|raw }}</div>
        {% endif %}
    </article>

    {% set hasAnyCard = cardsByBucket|filter(cards => cards is not empty)|length > 0 %}

    {% if not hasAnyCard %}
        <div class="alert alert-info">{{ 'app.staple_card.public.empty'|trans }}</div>
    {% else %}
        {% for bucket in buckets %}
            {% set cards = cardsByBucket[bucket] %}
            {% if cards is not empty %}
                <article class="card shadow-sm mb-4">
                    <div class="card-header card-header-themed">
                        <h2 class="mb-0 h5">{{ ('app.staple_card.bucket.' ~ bucket)|trans }}</h2>
                    </div>
                    <div class="card-body">
                        <div class="row row-cols-3 row-cols-sm-4 row-cols-md-6 row-cols-lg-9 g-3">
                            {% for card in cards %}
                                {% set highResImageUrl = imageUrls[card.id] ?? null %}
                                {% set imageUrl = highResImageUrl ? highResImageUrl|replace({'/high.webp': '/low.webp'}) : null %}
                                {% set printingsJson = card.printings|map(p => {setCode: p.setCode, cardNumber: p.cardNumber})|json_encode %}
                                <div class="col" id="staple-{{ card.id }}">
                                    <button type="button"
                                        class="staple-card-trigger btn p-0 border-0 bg-transparent w-100 position-relative"
                                        data-bs-toggle="modal"
                                        data-bs-target="#stapleCardModal"
                                        data-card-name="{{ card.cardName }}"
                                        data-card-image="{{ highResImageUrl ?? '' }}"
                                        data-card-note="{{ card.id in renderedNotes|keys ? renderedNotes[card.id] : '' }}"
                                        data-card-printings="{{ printingsJson }}"
                                        aria-label="{{ 'app.staple_card.public.view_details'|trans({'%name%': card.cardName}) }}">
                                        {% if imageUrl %}
                                            <img src="{{ imageUrl }}" alt="{{ card.cardName }}" class="img-fluid rounded shadow-sm" loading="lazy">
                                        {% else %}
                                            <div class="banned-card-placeholder rounded shadow-sm d-flex align-items-center justify-content-center text-center p-3">
                                                {% set firstPrinting = card.printings|first %}
                                                <span class="small fw-semibold">{{ card.cardName }}{% if firstPrinting %}<br><span class="text-muted">{{ firstPrinting.setCode }} {{ firstPrinting.cardNumber }}</span>{% endif %}</span>
                                            </div>
                                        {% endif %}
                                    </button>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                </article>
            {% endif %}
        {% endfor %}

        <div class="modal fade" id="stapleCardModal" tabindex="-1" aria-labelledby="stapleCardModalLabel" aria-hidden="true">
            <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable modal-lg">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title" id="stapleCardModalLabel"></h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body position-relative">
                        <button type="button" id="stapleCardModalPrev" class="btn btn-sm btn-outline-secondary position-absolute start-0 top-50 translate-middle-y ms-1" style="z-index: 2;" aria-label="{{ 'app.staple_card.modal.previous'|trans }}">&lsaquo;</button>
                        <button type="button" id="stapleCardModalNext" class="btn btn-sm btn-outline-secondary position-absolute end-0 top-50 translate-middle-y me-1" style="z-index: 2;" aria-label="{{ 'app.staple_card.modal.next'|trans }}">&rsaquo;</button>
                        <div class="row g-3">
                            <div class="col-md-5 text-center">
                                <img id="stapleCardModalImage" src="" alt="" class="img-fluid rounded">
                            </div>
                            <div class="col-md-7">
                                <h6 id="stapleCardModalNoteLabel" class="mb-2" hidden>{{ 'app.staple_card.modal.note'|trans }}</h6>
                                <div id="stapleCardModalNote" class="mb-3" hidden></div>
                                <h6 class="mb-2">{{ 'app.staple_card.modal.printings'|trans }}</h6>
                                <div id="stapleCardModalPrintings" class="d-flex flex-wrap gap-2 mb-0"></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    {% endif %}
{% endblock %}
