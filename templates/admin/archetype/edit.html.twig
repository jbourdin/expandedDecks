{% extends 'base.html.twig' %}

{% block title %}{{ 'app.archetype.edit_title'|trans({'%name%': archetype.name}) }} — {% include '_brand.html.twig' %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('archetype_form') }}
{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.archetype.edit_title'|trans({'%name%': archetype.name}) }}</h1>
        <div class="d-flex gap-2">
            {% if archetype.published %}
                <a href="{{ path('app_archetype_show', {slug: archetype.slug}) }}" class="btn btn-outline-primary" target="_blank">{{ 'app.common.view'|trans }}</a>
            {% else %}
                <a href="{{ path('app_archetype_show', {slug: archetype.slug}) }}?preview=true" class="btn btn-outline-warning" target="_blank"><i class="bi bi-eye me-1"></i>{{ 'app.common.preview'|trans }}</a>
            {% endif %}
            <a href="{{ path('app_admin_archetype_list') }}" class="btn btn-outline-secondary">{{ 'app.common.back'|trans }}</a>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.archetype.settings'|trans }}</h5>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_row(form.name) }}

                <div class="mb-3">
                    <label class="form-label">{{ 'app.archetype.pokemon_slugs_label'|trans }}</label>
                    <div id="pokemon-sprite-select-root"
                         data-values="{{ archetype.pokemonSlugs|json_encode }}"></div>
                    <p class="text-muted small mt-1">{{ 'app.archetype.pokemon_slugs_help'|trans }}</p>
                    {{ form_widget(form.pokemonSlugs) }}
                </div>

                <div class="mb-3">
                    <label class="form-label">{{ 'app.archetype.playstyle_tags_label'|trans }}</label>
                    <div id="playstyle-tag-select-root"
                         data-existing-tags="{{ existingTags|json_encode }}"
                         data-values="{{ archetype.playstyleTags|json_encode }}"
                         data-placeholder="{{ 'app.archetype.playstyle_tags_placeholder'|trans }}"></div>
                    {{ form_widget(form.playstyleTags, {id: 'playstyle-tags-hidden'}) }}
                </div>

                {{ form_row(form.isPublished) }}
                <button type="submit" class="btn btn-gold mt-3">{{ 'app.common.save'|trans }}</button>
            {{ form_end(form) }}
        </div>
    </div>

    {# Translations — tabbed card #}
    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed">
            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                {% for locale in supportedLocales %}
                    {% set translation = archetype.getTranslation(locale) %}
                    {% set hasTranslation = translation and translation.locale == locale %}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link {{ loop.first ? 'active' : '' }}" id="tab-{{ locale }}" data-bs-toggle="tab" data-bs-target="#pane-{{ locale }}" type="button" role="tab" aria-controls="pane-{{ locale }}" aria-selected="{{ loop.first ? 'true' : 'false' }}">
                            {{ locale|upper }}
                            {% if hasTranslation %}
                                <span class="badge bg-success ms-1">{{ 'app.cms.status.translated'|trans }}</span>
                            {% else %}
                                <span class="badge bg-warning text-dark ms-1">{{ 'app.cms.status.missing'|trans }}</span>
                            {% endif %}
                        </button>
                    </li>
                {% endfor %}
            </ul>
        </div>
        <div class="card-body">
            <div class="tab-content">
                {% for locale in supportedLocales %}
                    <div class="tab-pane fade {{ loop.first ? 'show active' : '' }}" id="pane-{{ locale }}" role="tabpanel" aria-labelledby="tab-{{ locale }}">
                        {% from 'admin/_rich_text_editor.html.twig' import rich_text_editor %}
                        {{ form_start(translationForms[locale]) }}
                            {{ form_row(translationForms[locale].name) }}
                            {{ rich_text_editor(translationForms[locale].description) }}
                            {{ form_row(translationForms[locale].metaDescription) }}
                            <button type="submit" class="btn btn-gold mt-3">{{ 'app.cms.admin.save_translation'|trans({'%locale%': locale|upper}) }}</button>
                        {{ form_end(translationForms[locale]) }}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {% if archetype.deletedAt is not null %}
        <div class="card shadow-sm border-warning mt-4">
            <div class="card-body">
                <span class="badge bg-danger">{{ 'app.common.deleted'|trans }}</span>
            </div>
        </div>
    {% elseif deckCount == 0 %}
        <div class="card shadow-sm border-danger mt-4">
            <div class="card-body">
                <h5 class="text-danger">{{ 'app.common.danger_zone'|trans }}</h5>
                <form method="post" action="{{ path('app_admin_archetype_delete', {id: archetype.id}) }}" onsubmit="return confirm('{{ 'app.admin.archetype.delete_confirm'|trans|e('js') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('archetype-delete-' ~ archetype.id) }}">
                    <button type="submit" class="btn btn-outline-danger">{{ 'app.admin.archetype.delete_button'|trans }}</button>
                </form>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('archetype_form') }}
    <script>
        {# Activate the correct translation tab based on URL hash #}
        (function() {
            var hash = window.location.hash;
            if (hash) {
                var tab = document.querySelector('[data-bs-target="' + hash + '"]');
                if (tab) { tab.click(); }
            }
        })();
    </script>
{% endblock %}
