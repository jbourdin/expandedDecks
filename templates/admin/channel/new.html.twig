{% extends 'base.html.twig' %}

{% block title %}{{ 'app.channel.new_title'|trans }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.channel.new_title'|trans }}</h1>
        <a href="{{ path('app_admin_channel_list') }}" class="btn btn-outline-secondary">{{ 'app.common.back'|trans }}</a>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.channel.settings'|trans }}</h5>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_row(form.code) }}
                {{ form_row(form.domain) }}
                <hr>
                {{ form_row(form.enableDecks) }}
                {{ form_row(form.enableRegister) }}
                {{ form_row(form.enableEvents) }}
                {{ form_row(form.enableBorrows) }}
                {{ form_row(form.enableArchetypes) }}
                <hr>
                {{ form_row(form.themeName) }}
                {{ form_row(form.locales) }}
                <hr>
                <h6>{{ 'app.channel.parameters'|trans }}</h6>
                <div id="parameters-collection" data-prototype="{{ form_widget(form.parameters.vars.prototype)|e('html_attr') }}">
                    {% for pair in form.parameters %}
                        <div class="row g-2 mb-2 parameter-row">
                            <div class="col-5">{{ form_widget(pair.key) }}</div>
                            <div class="col-5">{{ form_widget(pair.value) }}</div>
                            <div class="col-2"><button type="button" class="btn btn-sm btn-outline-danger remove-parameter">&times;</button></div>
                        </div>
                    {% endfor %}
                </div>
                <button type="button" class="btn btn-sm btn-outline-secondary mb-3" id="add-parameter">{{ 'app.channel.add_parameter'|trans }}</button>
                <br>
                <button type="submit" class="btn btn-gold mt-3">{{ 'app.common.create'|trans }}</button>
            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script>
        (function() {
            var container = document.getElementById('parameters-collection');
            var addButton = document.getElementById('add-parameter');
            var index = container.querySelectorAll('.parameter-row').length;
            var prototype = container.dataset.prototype;

            addButton.addEventListener('click', function() {
                var html = prototype.replace(/__name__/g, index);
                var wrapper = document.createElement('div');
                wrapper.innerHTML = html;
                var inputs = wrapper.querySelectorAll('input');
                var row = document.createElement('div');
                row.className = 'row g-2 mb-2 parameter-row';
                row.innerHTML = '<div class="col-5"></div><div class="col-5"></div><div class="col-2"><button type="button" class="btn btn-sm btn-outline-danger remove-parameter">&times;</button></div>';
                if (inputs[0]) row.children[0].appendChild(inputs[0]);
                if (inputs[1]) row.children[1].appendChild(inputs[1]);
                container.appendChild(row);
                index++;
            });

            container.addEventListener('click', function(event) {
                if (event.target.classList.contains('remove-parameter')) {
                    event.target.closest('.parameter-row').remove();
                }
            });
        })();
    </script>
{% endblock %}
