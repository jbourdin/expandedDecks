{% extends 'base.html.twig' %}

{% block title %}{{ 'app.channel.admin_list_title'|trans }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.channel.admin_list_title'|trans }}</h1>
        <a href="{{ path('app_admin_channel_new') }}" class="btn btn-gold">
            <i class="bi bi-plus-lg me-1"></i>{{ 'app.channel.create_button'|trans }}
        </a>
    </div>

    {% if channels is not empty %}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <table class="table table-striped table-themed mb-0">
                    <thead>
                        <tr>
                            <th>{{ 'app.channel.code'|trans }}</th>
                            <th>{{ 'app.channel.domain'|trans }}</th>
                            <th style="width: 80px">{{ 'app.channel.enable_decks'|trans }}</th>
                            <th style="width: 80px">{{ 'app.channel.enable_register'|trans }}</th>
                            <th style="width: 80px">{{ 'app.channel.enable_events'|trans }}</th>
                            <th style="width: 80px">{{ 'app.channel.enable_borrows'|trans }}</th>
                            <th style="width: 80px">{{ 'app.channel.is_archetype_source'|trans }}</th>
                            <th style="width: 60px"></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for channel in channels %}
                            <tr>
                                <td><code>{{ channel.code }}</code></td>
                                <td>{{ channel.domain }}</td>
                                <td>{% if channel.decksEnabled %}<span class="badge bg-success">{{ 'app.common.yes'|trans }}</span>{% else %}<span class="badge bg-secondary">{{ 'app.common.no'|trans }}</span>{% endif %}</td>
                                <td>{% if channel.registerEnabled %}<span class="badge bg-success">{{ 'app.common.yes'|trans }}</span>{% else %}<span class="badge bg-secondary">{{ 'app.common.no'|trans }}</span>{% endif %}</td>
                                <td>{% if channel.eventsEnabled %}<span class="badge bg-success">{{ 'app.common.yes'|trans }}</span>{% else %}<span class="badge bg-secondary">{{ 'app.common.no'|trans }}</span>{% endif %}</td>
                                <td>{% if channel.borrowsEnabled %}<span class="badge bg-success">{{ 'app.common.yes'|trans }}</span>{% else %}<span class="badge bg-secondary">{{ 'app.common.no'|trans }}</span>{% endif %}</td>
                                <td>{% if channel.archetypeSource %}<span class="badge bg-success">{{ 'app.common.yes'|trans }}</span>{% else %}<span class="badge bg-secondary">{{ 'app.common.no'|trans }}</span>{% endif %}</td>
                                <td>
                                    <a href="{{ path('app_admin_channel_edit', {id: channel.id}) }}" class="btn btn-sm btn-outline-secondary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    {% else %}
        <div class="alert alert-info">{{ 'app.channel.no_channels'|trans }}</div>
    {% endif %}
{% endblock %}
