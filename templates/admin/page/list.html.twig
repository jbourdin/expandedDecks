{% extends 'base.html.twig' %}

{% block title %}{{ 'app.cms.admin.pages_title'|trans }} — {{ channel_param('brand_name', 'Expanded Decks') }}{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.cms.admin.pages_title'|trans }}</h1>
        <a href="{{ path('app_admin_page_new') }}" class="btn btn-gold">{{ 'app.cms.admin.new_page'|trans }}</a>
    </div>

    <div class="d-flex flex-wrap gap-3 mb-4">
        <div class="btn-group" role="group" aria-label="{{ 'app.cms.admin.channel_filter'|trans }}">
            {% for channel in channels %}
                <a href="{{ path('app_admin_page_list', {channel: channel.code, q: search}) }}" class="btn {{ currentChannel and currentChannel.code == channel.code ? 'btn-gold' : 'btn-outline-secondary' }}">
                    {{ channel.domain }}
                </a>
            {% endfor %}
        </div>
        {% if categories is not empty %}
            <div class="btn-group" role="group" aria-label="{{ 'app.cms.admin.table.category'|trans }}">
                {% for category in categories %}
                    <a href="{{ path('app_admin_page_list', {channel: currentChannel ? currentChannel.code : '', category: category.id, q: search}) }}" class="btn {{ currentCategory and currentCategory.id == category.id ? 'btn-gold' : 'btn-outline-secondary' }}">
                        {{ category.getName(app.request.locale) }}
                    </a>
                {% endfor %}
            </div>
        {% endif %}
    </div>

    <form method="get" action="{{ path('app_admin_page_list') }}" class="card shadow-sm mb-4">
        {% if currentChannel %}<input type="hidden" name="channel" value="{{ currentChannel.code }}">{% endif %}
        {% if currentCategory %}<input type="hidden" name="category" value="{{ currentCategory.id }}">{% endif %}
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label for="q" class="form-label">{{ 'app.common.search'|trans }}</label>
                    <input type="text" id="q" name="q" class="form-control" value="{{ search }}" placeholder="{{ 'app.cms.admin.search_placeholder'|trans }}">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-gold flex-fill">{{ 'app.common.filter'|trans }}</button>
                    {% if search is not empty %}
                        <a href="{{ path('app_admin_page_list', {channel: currentChannel ? currentChannel.code : '', category: currentCategory ? currentCategory.id : ''}) }}" class="btn btn-outline-secondary">{{ 'app.common.clear'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </form>

    {% if totalItems > 0 %}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-themed mb-0">
                        <thead>
                            <tr>
                                {% if sortableEnabled %}
                                    <th style="width: 50px"></th>
                                {% endif %}
                                <th>{{ 'app.common.slug'|trans }}</th>
                                <th>{{ 'app.cms.admin.table.title'|trans }}</th>
                                {% if not currentCategory %}
                                    <th>{{ 'app.cms.admin.table.category'|trans }}</th>
                                {% endif %}
                                <th>{{ 'app.common.status'|trans }}</th>
                                <th>{{ 'app.cms.admin.table.created'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody id="sortable-pages" data-reorder-url="{{ path('app_admin_page_reorder') }}">
                            {% for page in contentPages %}
                                <tr data-page-id="{{ page.id }}">
                                    {% if sortableEnabled %}
                                        <td class="text-center align-middle">
                                            <span class="sortable-handle d-none d-md-inline" style="cursor: grab" aria-label="{{ 'app.cms.admin.drag_to_reorder'|trans }}"><i class="bi bi-grip-vertical"></i></span>
                                            <span class="d-inline d-md-none">
                                                <button type="button" class="btn btn-sm btn-link p-0 move-up-btn" aria-label="{{ 'app.cms.admin.move_up'|trans }}"><i class="bi bi-chevron-up"></i></button>
                                                <button type="button" class="btn btn-sm btn-link p-0 move-down-btn" aria-label="{{ 'app.cms.admin.move_down'|trans }}"><i class="bi bi-chevron-down"></i></button>
                                            </span>
                                        </td>
                                    {% endif %}
                                    <td><code>{{ page.slug }}</code></td>
                                    <td>
                                        {{ page.getTitle(app.request.locale) }}
                                        {% set missingLocales = [] %}
                                        {% for locale in supportedLocales %}
                                            {% set t = page.getTranslation(locale) %}
                                            {% if not t or t.locale != locale %}
                                                {% set missingLocales = missingLocales|merge([locale|upper]) %}
                                            {% endif %}
                                        {% endfor %}
                                        {% if missingLocales is not empty %}
                                            <i class="bi bi-translate text-warning ms-1" data-bs-toggle="tooltip" title="{{ 'app.cms.admin.missing_translations'|trans({'%locales%': missingLocales|join(', ')}) }}"></i>
                                        {% endif %}
                                    </td>
                                    {% if not currentCategory %}
                                        <td>
                                            {% if page.menuCategory %}
                                                <a href="{{ path('app_admin_page_list', {category: page.menuCategory.id}) }}" class="badge bg-secondary text-decoration-none">{{ page.menuCategory.getName(app.request.locale) }}</a>
                                            {% endif %}
                                        </td>
                                    {% endif %}
                                    <td>
                                        {% if page.deletedAt is not null %}
                                            <span class="badge bg-danger">{{ 'app.common.deleted'|trans }}</span>
                                        {% elseif page.published %}
                                            <span class="badge bg-success">{{ 'app.common.published'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">{{ 'app.cms.status.draft'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ page.createdAt|date('Y-m-d') }}</td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle no-caret" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'app.common.actions'|trans }}">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                {% if page.published %}
                                                    <li><a class="dropdown-item" href="{{ page.channel ? channel_url(page.channel.code, 'app_page_show', {slug: page.slug}) : path('app_page_show', {slug: page.slug}) }}" target="_blank"><i class="bi bi-eye me-2"></i>{{ 'app.common.view'|trans }}</a></li>
                                                {% else %}
                                                    <li><a class="dropdown-item" href="{{ page.channel ? channel_url(page.channel.code, 'app_page_show', {slug: page.slug}) : path('app_page_show', {slug: page.slug}) }}?preview=true" target="_blank"><i class="bi bi-eye me-2"></i>{{ 'app.common.preview'|trans }}</a></li>
                                                {% endif %}
                                                <li><a class="dropdown-item" href="{{ path('app_admin_page_edit', {id: page.id}) }}"><i class="bi bi-pencil me-2"></i>{{ 'app.common.edit'|trans }}</a></li>
                                                <li>
                                                    <form method="post" action="{{ path('app_admin_page_duplicate', {id: page.id}) }}" class="d-inline">
                                                        <input type="hidden" name="_token" value="{{ csrf_token('page-duplicate-' ~ page.id) }}">
                                                        <button type="submit" class="dropdown-item"><i class="bi bi-copy me-2"></i>{{ 'app.cms.admin.duplicate_page'|trans }}</button>
                                                    </form>
                                                </li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {% if totalPages > 1 %}
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_admin_page_list', {q: search, category: currentCategory ? currentCategory.id : '', page: currentPage - 1}) }}">
                            {{ 'app.common.previous'|trans }}
                        </a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item {% if p == currentPage %}active{% endif %}">
                            <a class="page-link" href="{{ path('app_admin_page_list', {q: search, category: currentCategory ? currentCategory.id : '', page: p}) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_admin_page_list', {q: search, category: currentCategory ? currentCategory.id : '', page: currentPage + 1}) }}">
                            {{ 'app.common.next'|trans }}
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="alert alert-info">{{ 'app.cms.admin.no_pages'|trans }}</div>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if sortableEnabled %}
        {{ encore_entry_script_tags('admin_page_list') }}
    {% endif %}
{% endblock %}
