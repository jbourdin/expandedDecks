{% extends 'base.html.twig' %}

{% block title %}{{ 'app.cms.admin.pages_title'|trans }} — Expanded Decks{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.cms.admin.pages_title'|trans }}</h1>
        <a href="{{ path('app_admin_page_new') }}" class="btn btn-gold">{{ 'app.cms.admin.new_page'|trans }}</a>
    </div>

    <form method="get" action="{{ path('app_admin_page_list') }}" class="card shadow-sm mb-4">
        <div class="card-body">
            <div class="row g-2 align-items-end">
                <div class="col-md-9">
                    <label for="q" class="form-label">{{ 'app.common.search'|trans }}</label>
                    <input type="text" id="q" name="q" class="form-control" value="{{ search }}" placeholder="{{ 'app.cms.admin.search_placeholder'|trans }}">
                </div>
                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-gold flex-fill">{{ 'app.common.filter'|trans }}</button>
                    {% if search is not empty %}
                        <a href="{{ path('app_admin_page_list') }}" class="btn btn-outline-secondary">{{ 'app.common.clear'|trans }}</a>
                    {% endif %}
                </div>
            </div>
        </div>
    </form>

    {% if totalItems > 0 %}
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-striped table-themed mb-0">
                        <thead>
                            <tr>
                                <th>{{ 'app.common.slug'|trans }}</th>
                                <th>{{ 'app.cms.admin.table.title'|trans }}</th>
                                <th>{{ 'app.cms.admin.table.category'|trans }}</th>
                                <th>{{ 'app.common.status'|trans }}</th>
                                <th>{{ 'app.cms.admin.table.created'|trans }}</th>
                                <th></th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for page in contentPages %}
                                <tr>
                                    <td><code>{{ page.slug }}</code></td>
                                    <td>
                                        {{ page.getTitle(app.request.locale) }}
                                        {% set missingLocales = [] %}
                                        {% for locale in supportedLocales %}
                                            {% set t = page.getTranslation(locale) %}
                                            {% if not t or t.locale != locale %}
                                                {% set missingLocales = missingLocales|merge([locale|upper]) %}
                                            {% endif %}
                                        {% endfor %}
                                        {% if missingLocales is not empty %}
                                            <i class="bi bi-translate text-warning ms-1" data-bs-toggle="tooltip" title="{{ 'app.cms.admin.missing_translations'|trans({'%locales%': missingLocales|join(', ')}) }}"></i>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if page.menuCategory %}
                                            <span class="badge bg-secondary">{{ page.menuCategory.getName(app.request.locale) }}</span>
                                        {% endif %}
                                    </td>
                                    <td>
                                        {% if page.deletedAt is not null %}
                                            <span class="badge bg-danger">{{ 'app.common.deleted'|trans }}</span>
                                        {% elseif page.published %}
                                            <span class="badge bg-success">{{ 'app.common.published'|trans }}</span>
                                        {% else %}
                                            <span class="badge bg-warning text-dark">{{ 'app.cms.status.draft'|trans }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ page.createdAt|date('Y-m-d') }}</td>
                                    <td>
                                        <div class="dropdown">
                                            <button class="btn btn-sm btn-outline-secondary dropdown-toggle no-caret" type="button" data-bs-toggle="dropdown" aria-expanded="false" aria-label="{{ 'app.common.actions'|trans }}">
                                                <i class="bi bi-three-dots-vertical"></i>
                                            </button>
                                            <ul class="dropdown-menu dropdown-menu-end">
                                                {% if page.published %}
                                                    <li><a class="dropdown-item" href="{{ path('app_page_show', {slug: page.slug}) }}" target="_blank"><i class="bi bi-eye me-2"></i>{{ 'app.common.view'|trans }}</a></li>
                                                {% else %}
                                                    <li><a class="dropdown-item" href="{{ path('app_page_show', {slug: page.slug}) }}?preview=true" target="_blank"><i class="bi bi-eye me-2"></i>{{ 'app.common.preview'|trans }}</a></li>
                                                {% endif %}
                                                <li><a class="dropdown-item" href="{{ path('app_admin_page_edit', {id: page.id}) }}"><i class="bi bi-pencil me-2"></i>{{ 'app.common.edit'|trans }}</a></li>
                                            </ul>
                                        </div>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        {% if totalPages > 1 %}
            <nav class="mt-3">
                <ul class="pagination justify-content-center">
                    <li class="page-item {% if currentPage <= 1 %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_admin_page_list', {q: search, page: currentPage - 1}) }}">
                            {{ 'app.common.previous'|trans }}
                        </a>
                    </li>
                    {% for p in 1..totalPages %}
                        <li class="page-item {% if p == currentPage %}active{% endif %}">
                            <a class="page-link" href="{{ path('app_admin_page_list', {q: search, page: p}) }}">{{ p }}</a>
                        </li>
                    {% endfor %}
                    <li class="page-item {% if currentPage >= totalPages %}disabled{% endif %}">
                        <a class="page-link" href="{{ path('app_admin_page_list', {q: search, page: currentPage + 1}) }}">
                            {{ 'app.common.next'|trans }}
                        </a>
                    </li>
                </ul>
            </nav>
        {% endif %}
    {% else %}
        <div class="alert alert-info">{{ 'app.cms.admin.no_pages'|trans }}</div>
    {% endif %}
{% endblock %}
