{% extends 'base.html.twig' %}

{% block title %}{{ 'app.cms.admin.edit_page'|trans }} — Expanded Decks{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    {{ encore_entry_link_tags('page_form') }}
{% endblock %}

{% block body %}
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">{{ 'app.cms.admin.edit_page'|trans }}: {{ page.slug }}</h1>
        <div class="d-flex gap-2">
            {% if page.published %}
                <a href="{{ path('app_page_show', {slug: page.slug}) }}" class="btn btn-outline-primary" target="_blank">{{ 'app.common.view'|trans }}</a>
            {% else %}
                <a href="{{ path('app_page_show', {slug: page.slug}) }}?preview=true" class="btn btn-outline-warning" target="_blank"><i class="bi bi-eye me-1"></i>{{ 'app.common.preview'|trans }}</a>
            {% endif %}
            <a href="{{ path('app_admin_page_list') }}" class="btn btn-outline-secondary">{{ 'app.common.back'|trans }}</a>
        </div>
    </div>

    {# Page settings #}
    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.cms.admin.page_settings'|trans }}</h5>
        </div>
        <div class="card-body">
            {{ form_start(form) }}
                {{ form_widget(form) }}
                <button type="submit" class="btn btn-gold mt-3">{{ 'app.common.save'|trans }}</button>
            {{ form_end(form) }}
        </div>
    </div>

    {# Translations — tabbed card #}
    <div class="card shadow-sm mb-4">
        <div class="card-header card-header-themed">
            <ul class="nav nav-tabs card-header-tabs" role="tablist">
                {% for locale in supportedLocales %}
                    {% set translation = page.getTranslation(locale) %}
                    {% set hasTranslation = translation and translation.locale == locale %}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link {{ loop.first ? 'active' : '' }}" id="tab-{{ locale }}" data-bs-toggle="tab" data-bs-target="#pane-{{ locale }}" type="button" role="tab" aria-controls="pane-{{ locale }}" aria-selected="{{ loop.first ? 'true' : 'false' }}">
                            {{ locale|upper }}
                            {% if hasTranslation %}
                                <span class="badge bg-success ms-1">{{ 'app.cms.status.translated'|trans }}</span>
                            {% else %}
                                <span class="badge bg-warning text-dark ms-1">{{ 'app.cms.status.missing'|trans }}</span>
                            {% endif %}
                        </button>
                    </li>
                {% endfor %}
            </ul>
        </div>
        <div class="card-body">
            <div class="tab-content">
                {% for locale in supportedLocales %}
                    <div class="tab-pane fade {{ loop.first ? 'show active' : '' }}" id="pane-{{ locale }}" role="tabpanel" aria-labelledby="tab-{{ locale }}">
                        {% from 'admin/_rich_text_editor.html.twig' import rich_text_editor %}
                        {% from 'admin/_image_url_field.html.twig' import image_url_field %}
                        {{ form_start(translationForms[locale]) }}
                            {{ form_row(translationForms[locale].title) }}
                            {{ form_row(translationForms[locale].slug) }}
                            {{ rich_text_editor(translationForms[locale].content) }}
                            {{ form_row(translationForms[locale].metaTitle) }}
                            {{ form_row(translationForms[locale].metaDescription) }}
                            {{ image_url_field(translationForms[locale].ogImage) }}
                            <button type="submit" class="btn btn-gold mt-3">{{ 'app.cms.admin.save_translation'|trans({'%locale%': locale|upper}) }}</button>
                        {{ form_end(translationForms[locale]) }}
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>

    {# Delete #}
    {% if page.deletedAt is null %}
        <div class="card shadow-sm border-danger">
            <div class="card-body">
                <h5 class="text-danger">{{ 'app.common.danger_zone'|trans }}</h5>
                <form method="post" action="{{ path('app_admin_page_delete', {id: page.id}) }}" onsubmit="return confirm('{{ 'app.cms.admin.delete_confirm'|trans|e('js') }}')">
                    <input type="hidden" name="_token" value="{{ csrf_token('page-delete-' ~ page.id) }}">
                    <button type="submit" class="btn btn-outline-danger">{{ 'app.cms.admin.delete_page'|trans }}</button>
                </form>
            </div>
        </div>
    {% else %}
        <div class="card shadow-sm border-warning">
            <div class="card-body">
                <span class="badge bg-danger">{{ 'app.common.deleted'|trans }}</span>
            </div>
        </div>
    {% endif %}
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {{ encore_entry_script_tags('page_form') }}
    <script>
        {# Activate the correct translation tab based on URL hash #}
        (function() {
            var hash = window.location.hash;
            if (hash) {
                var tab = document.querySelector('[data-bs-target="' + hash + '"]');
                if (tab) { tab.click(); }
            }
        })();
    </script>
{% endblock %}
