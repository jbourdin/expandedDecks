{% extends 'base.html.twig' %}

{% block title %}{{ 'app.admin.technical.title'|trans }} — {% include '_brand.html.twig' %}{% endblock %}

{% block body %}
    <h2 class="mb-4">{{ 'app.admin.technical.title'|trans }}</h2>

    {# Deck enrichment card #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.admin.technical.enrich.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.enrich.description'|trans }}</p>

            {% if pendingEnrichments|length > 0 %}
                <div class="alert alert-warning">
                    {{ 'app.admin.technical.enrich.pending_count'|trans({'%count%': pendingEnrichments|length}) }}
                </div>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>{{ 'app.common.deck'|trans }}</th>
                            <th>{{ 'app.admin.technical.enrich.table.version'|trans }}</th>
                            <th>{{ 'app.common.status'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for version in pendingEnrichments %}
                            <tr>
                                <td>{{ version.deck.name }}</td>
                                <td>v{{ version.versionNumber }}</td>
                                <td>
                                    <span class="badge bg-{{ version.enrichmentStatus == 'failed' ? 'danger' : 'secondary' }}">
                                        {{ version.enrichmentStatus }}
                                    </span>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <form method="post" action="{{ path('app_admin_technical_enrich_retry') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('technical-enrich-retry') }}">
                    <button type="submit" class="btn btn-gold">
                        {{ 'app.admin.technical.enrich.retry_button'|trans }}
                    </button>
                </form>
            {% else %}
                <div class="alert alert-success mb-0">
                    {{ 'app.admin.technical.enrich.all_done'|trans }}
                </div>
            {% endif %}
        </div>
    </div>

    {# Mosaic generation card #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.admin.technical.mosaic.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.mosaic.description'|trans }}</p>

            {% if pendingMosaics|length > 0 %}
                <div class="alert alert-warning">
                    {{ 'app.admin.technical.mosaic.pending_count'|trans({'%count%': pendingMosaics|length}) }}
                </div>
                <table class="table table-sm">
                    <thead>
                        <tr>
                            <th>{{ 'app.common.deck'|trans }}</th>
                            <th>{{ 'app.admin.technical.enrich.table.version'|trans }}</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for version in pendingMosaics %}
                            <tr>
                                <td>{{ version.deck.name }}</td>
                                <td>v{{ version.versionNumber }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                <form method="post" action="{{ path('app_admin_technical_mosaic_generate') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('technical-mosaic-generate') }}">
                    <button type="submit" class="btn btn-gold">
                        {{ 'app.admin.technical.mosaic.generate_button'|trans }}
                    </button>
                </form>
            {% else %}
                <div class="alert alert-success mb-0">
                    {{ 'app.admin.technical.mosaic.all_done'|trans }}
                </div>
            {% endif %}
        </div>
    </div>

    {# TCGdex set mappings card #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.admin.technical.set_mappings.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.set_mappings.description'|trans }}</p>

            <div class="mb-3">
                {% if setMappingCount > 0 %}
                    <span class="badge bg-success">{{ 'app.admin.technical.set_mappings.count'|trans({'%count%': setMappingCount}) }}</span>
                {% else %}
                    <span class="badge bg-warning">{{ 'app.admin.technical.set_mappings.empty'|trans }}</span>
                {% endif %}
            </div>

            <form method="post" action="{{ path('app_admin_technical_set_mappings_rebuild') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('technical-set-mappings-rebuild') }}">
                <button type="submit" class="btn btn-gold"
                        onclick="return confirm('{{ 'app.admin.technical.set_mappings.confirm_rebuild'|trans|e('js') }}')">
                    {{ 'app.admin.technical.set_mappings.rebuild_button'|trans }}
                </button>
            </form>
        </div>
    </div>

    {# Banned cards sync card #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.admin.technical.banned_cards.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.banned_cards.description'|trans }}</p>

            <div class="mb-3">
                {{ 'app.admin.technical.banned_cards.current_count'|trans({'%count%': bannedCardCount}) }}
            </div>

            <form method="post" action="{{ path('app_admin_technical_banned_cards_sync') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('technical-banned-cards-sync') }}">
                <button type="submit" class="btn btn-gold"
                        onclick="return confirm('{{ 'app.admin.technical.banned_cards.confirm_sync'|trans|e('js') }}')">
                    {{ 'app.admin.technical.banned_cards.sync_button'|trans }}
                </button>
            </form>
        </div>
    </div>

    {# Flush & Re-enrich card — danger zone #}
    <div class="card shadow-sm mb-3 border-danger">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">{{ 'app.admin.technical.flush_reenrich.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.flush_reenrich.description'|trans }}</p>
            <div class="alert alert-danger">
                {{ 'app.admin.technical.flush_reenrich.warning'|trans }}
            </div>
            <form method="post" action="{{ path('app_admin_technical_flush_reenrich') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('technical-flush-reenrich') }}">
                <button type="submit" class="btn btn-danger"
                        onclick="return confirm('{{ 'app.admin.technical.flush_reenrich.confirm'|trans|e('js') }}')">
                    {{ 'app.admin.technical.flush_reenrich.button'|trans }}
                </button>
            </form>
        </div>
    </div>

    {# Clear cache card #}
    <div class="card shadow-sm mb-3">
        <div class="card-header card-header-themed">
            <h5 class="mb-0">{{ 'app.admin.technical.clear_cache.title'|trans }}</h5>
        </div>
        <div class="card-body">
            <p>{{ 'app.admin.technical.clear_cache.description'|trans }}</p>
            <form method="post" action="{{ path('app_admin_technical_clear_cache') }}">
                <input type="hidden" name="_token" value="{{ csrf_token('technical-clear-cache') }}">
                <button type="submit" class="btn btn-outline-secondary">
                    {{ 'app.admin.technical.clear_cache.button'|trans }}
                </button>
            </form>
        </div>
    </div>
{% endblock %}
