 # RSS 2.0 feed of the most recently published pages in a menu category.
 # The comment closes with a whitespace-trimming tag so the XML declaration
 # stays at the very first byte of the response (required by the XML spec).
 #
 # @see docs/features.md F21.1 — RSS feed per page category
 -#}
<?xml version="1.0" encoding="UTF-8"?>
{%- set feedTitle = 'app.cms.feed.title_for_category'|trans({'%category%': category.getName(locale), '%brand%': channel_param('brand_name', 'Expanded Decks')}) %}
{%- set feedLink = url('app_page_category', {id: category.id}) %}
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom" xmlns:media="http://search.yahoo.com/mrss/">
    <channel>
        <title>{{ feedTitle }}</title>
        <link>{{ feedLink }}</link>
        <atom:link href="{{ url('app_page_category_feed', {id: category.id}) }}" rel="self" type="application/rss+xml"/>
        <description>{{ 'app.cms.feed.description_for_category'|trans({'%category%': category.getName(locale)}) }}</description>
        <language>{{ locale }}</language>
        {{- include('_partials/feed_image.xml.twig', {imageTitle: feedTitle, imageLink: feedLink}) -}}
        {%- if items|length > 0 %}
        <lastBuildDate>{{ (items|first).publishedAt|date('r') }}</lastBuildDate>
        {%- endif %}
        {%- for item in items %}
        <item>
            <title>{{ item.title }}</title>
            <link>{{ item.url }}</link>
            <guid isPermaLink="true">{{ item.url }}</guid>
            <pubDate>{{ item.publishedAt|date('r') }}</pubDate>
            {%- if item.description is not empty %}
            <description>{{ item.description }}</description>
            {%- endif %}
            {%- if item.image %}
            <media:content url="{{ channel_absolute_url(item.image) }}" medium="image"/>
            {%- endif %}
        </item>
        {%- endfor %}
    </channel>
</rss>
